<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="{{ basePath }}styles.css" />
</head>
<body>
  <header class="site-header">
    <div>
      <h1>{{ title }}</h1>
      {% if subtitle %}<p class="site-subtitle">{{ subtitle }}</p>{% endif %}
    </div>
    <div class="site-meta">
      <span>Updated {{ generatedAt }}</span>
      {% if showNav %}
      <nav class="site-nav" aria-label="Primary">
        <a href="{{ basePath }}index.html" class="{% if activeNav == 'projects' %}active{% endif %}" {% if activeNav == 'projects' %}aria-current="page"{% endif %}>Projects</a>
        <a href="{{ basePath }}partners/index.html" class="{% if activeNav == 'partners' %}active{% endif %}" {% if activeNav == 'partners' %}aria-current="page"{% endif %}>Partners</a>
      </nav>
      {% endif %}
    </div>
  </header>
  <main>
    {{ content | safe }}
  </main>

  {% if includeChat %}
  <!--Start of Tawk.to Script-->
  <script type="text/javascript">
  var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
  (function(){
  var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
  s1.async=true;
  s1.src='https://embed.tawk.to/69ab45659a31f71c36661195/1jj2ge56a';
  s1.charset='UTF-8';
  s1.setAttribute('crossorigin','*');
  s0.parentNode.insertBefore(s1,s0);
  })();
  </script>
  <!--End of Tawk.to Script-->
  {% endif %}

  <script>
    const initCardPortals = () => {
      document.querySelectorAll('[data-portal]').forEach(card => {
        card.addEventListener('click', event => {
          if (event.target.closest('[data-noportal]')) return;
          const url = card.getAttribute('data-portal');
          if (url) window.open(url, '_blank');
        });
      });
      document.querySelectorAll('[data-noportal]').forEach(link => {
        link.addEventListener('click', event => event.stopPropagation());
      });
    };

    const initSearchFilters = () => {
      document.querySelectorAll('[data-search-input]').forEach(input => {
        const group = input.getAttribute('data-search-input');
        const list = document.querySelector(`[data-search-list="${group}"]`);
        const items = list
          ? Array.from(list.querySelectorAll(`[data-search-item="${group}"]`))
          : Array.from(document.querySelectorAll(`[data-search-item="${group}"]`));
        if (!items.length) return;
        const emptyState = document.querySelector(`[data-search-empty="${group}"]`);
        const counter = document.querySelector(`[data-search-count="${group}"]`);
        const update = () => {
          const query = input.value.trim().toLowerCase();
          let visible = 0;
          items.forEach(item => {
            const text = (item.getAttribute('data-search-text') || '').toLowerCase();
            const matches = !query || text.includes(query);
            item.style.display = matches ? '' : 'none';
            if (matches) visible += 1;
          });
          if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
          if (counter) {
            const total = items.length;
            counter.textContent = visible === total ? `Showing all ${total}` : `Showing ${visible} of ${total}`;
          }
        };
        input.addEventListener('input', update);
        update();
      });
    };

    document.addEventListener('DOMContentLoaded', () => {
      initCardPortals();
      initSearchFilters();
      initAtlasChat();
    });

    // ── Atlas Chat ────────────────────────────────────────────────────────
    function initAtlasChat() {
      const container = document.getElementById('chatMessages');
      const form = document.getElementById('chatForm');
      const input = document.getElementById('chatInput');
      const sendBtn = document.getElementById('chatSend');
      if (!container || !form) return;

      let lastUpdateId = null;
      let rendered = new Set();

      function formatTime(unixTs) {
        const d = new Date(unixTs * 1000);
        return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }

      function addBubble(msg, outgoing) {
        if (rendered.has(msg.message_id)) return;
        rendered.add(msg.message_id);
        const bubble = document.createElement('div');
        bubble.className = `chat-bubble ${outgoing ? 'outgoing' : 'incoming'}`;
        bubble.innerHTML = `
          <div class="chat-bubble-text">${msg.text.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
          <span class="chat-bubble-meta">${outgoing ? 'You' : msg.from} · ${formatTime(msg.date)}</span>
        `;
        container.appendChild(bubble);
        container.scrollTop = container.scrollHeight;
      }

      async function fetchMessages() {
        try {
          const url = lastUpdateId
            ? `/api/telegram-messages?offset=${lastUpdateId + 1}`
            : `/api/telegram-messages`;
          const res = await fetch(url);
          if (!res.ok) return;
          const data = await res.json();
          if (data.messages && data.messages.length) {
            // Clear empty state
            const empty = container.querySelector('.chat-empty');
            if (empty) empty.remove();
            data.messages.forEach(msg => {
              addBubble(msg, false);
              lastUpdateId = Math.max(lastUpdateId || 0, msg.update_id);
            });
          } else if (!rendered.size) {
            const empty = container.querySelector('.chat-empty');
            if (empty) empty.textContent = 'No messages yet. Say hi to Atlas!';
          }
        } catch (e) {
          console.warn('Chat fetch error:', e);
        }
      }

      async function sendMessage(text) {
        sendBtn.disabled = true;
        try {
          const res = await fetch('/api/telegram-send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text }),
          });
          if (res.ok) {
            const data = await res.json();
            if (data.result) {
              const empty = container.querySelector('.chat-empty');
              if (empty) empty.remove();
              addBubble({
                message_id: data.result.message_id,
                from: 'You',
                text,
                date: data.result.date,
              }, true);
            }
          }
        } catch (e) {
          console.warn('Chat send error:', e);
        } finally {
          sendBtn.disabled = false;
          input.focus();
        }
      }

      form.addEventListener('submit', () => {
        const text = input.value.trim();
        if (!text) return;
        input.value = '';
        sendMessage(text);
      });

      // Poll every 4 seconds
      fetchMessages();
      setInterval(fetchMessages, 4000);
    }
  </script>

</body>
</html>
