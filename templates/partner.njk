<section class="partner-profile">
  <div class="partner-summary">
    <div>
      <h2>{{ partner.name }}</h2>
      <p class="muted">{{ partner.summary }}</p>
      <p>{{ partner.description }}</p>
      <ul class="tag-list">
        {% for tag in partner.tags or [] %}<li>{{ tag }}</li>{% endfor %}
      </ul>
    </div>
    <dl class="partner-meta">
      <div><dt>Website</dt><dd>{% if partner.website %}<a href="{{ partner.website }}" target="_blank">{{ partner.website }}</a>{% else %}—{% endif %}</dd></div>
      <div><dt>Contact</dt><dd>{{ partner.contact or '—' }}</dd></div>
      {% if partner.email %}<div><dt>Email</dt><dd><a href="mailto:{{ partner.email }}">{{ partner.email }}</a></dd></div>{% endif %}
      {% if partner.phone %}<div><dt>Phone</dt><dd><a href="tel:{{ partner.phone }}">{{ partner.phone }}</a></dd></div>{% endif %}
      {% if partner.linkedin %}<div><dt>LinkedIn</dt><dd><a href="{{ partner.linkedin }}" target="_blank" rel="noopener">Profile</a></dd></div>{% endif %}
      {% if partner.partnershipType %}<div><dt>Partnership</dt><dd>{{ partner.partnershipType }}</dd></div>{% endif %}
      <div><dt>Region</dt><dd>{{ partner.region or '—' }}</dd></div>
      <div><dt>Focus areas</dt><dd>{{ (partner.focusAreas and partner.focusAreas | join(', ')) or '—' }}</dd></div>
      <div id="partner-call-stats-row" style="display:none">
        <dt>Last call</dt>
        <dd id="partner-last-call-val">—</dd>
      </div>
      <div id="partner-call-count-row" style="display:none">
        <dt>Total calls</dt>
        <dd id="partner-call-count-val">—</dd>
      </div>
    </dl>
  </div>
</section>

{# ── Affiliate Program Section ── #}
<section class="partner-affiliate" id="affiliate-section">
  {# ── VIEW MODE ── #}
  <div id="aff-view">
    <header class="section-header">
      <div>
        {% if partner.affiliate %}
          <h3>Affiliate Program</h3>
          <p class="muted">{{ partner.affiliate.program_name or 'Untitled program' }}</p>
        {% else %}
          <h3>Affiliate Program</h3>
          <p class="muted">No affiliate program added yet.</p>
        {% endif %}
      </div>
      <div style="display:flex;align-items:center;gap:0.75rem;">
        {% if partner.affiliate %}
          <span class="aff-status-badge status-{{ partner.affiliate.status }}">
            {% if partner.affiliate.status == 'active' %}✓ Active
            {% elif partner.affiliate.status == 'pending' %}⏳ Pending
            {% else %}→ Apply now{% endif %}
          </span>
        {% endif %}
        <button class="btn btn-secondary btn-sm" onclick="showAffEdit()">
          {% if partner.affiliate %}✏️ Edit{% else %}+ Add affiliate program{% endif %}
        </button>
      </div>
    </header>

    {% if partner.affiliate %}
    <div class="aff-detail-metrics">
      <div class="aff-detail-metric">
        <span class="aff-detail-val">{{ partner.affiliate.commission }}</span>
        <span class="aff-detail-label">Commission structure</span>
      </div>
      <div class="aff-detail-metric">
        <span class="aff-detail-val">${{ partner.affiliate.avg_deal_size }}</span>
        <span class="aff-detail-label">Avg deal size</span>
      </div>
      <div class="aff-detail-metric">
        <span class="aff-detail-val">{{ partner.affiliate.monthly_leads }}/mo</span>
        <span class="aff-detail-label">Est. monthly leads</span>
      </div>
      <div class="aff-detail-metric highlight">
        <span class="aff-detail-val aff-potential" id="aff-view-potential">${{ partner.affiliate.monthly_potential }}</span>
        <span class="aff-detail-label">Est. monthly revenue</span>
      </div>
    </div>
    {% if partner.affiliate.notes %}
    <p class="aff-program-notes" id="aff-view-notes">{{ partner.affiliate.notes }}</p>
    {% endif %}
    <div class="aff-program-links">
      {% if partner.affiliate.affiliate_url %}<a href="{{ partner.affiliate.affiliate_url }}" target="_blank" class="btn btn-secondary">Program page →</a>{% endif %}
      {% if partner.affiliate.signup_url and partner.affiliate.status != 'active' %}<a href="{{ partner.affiliate.signup_url }}" target="_blank" class="btn">Apply to program →</a>{% endif %}
    </div>
    {% endif %}
  </div>

  {# ── EDIT MODE ── #}
  <div id="aff-edit" style="display:none;">
    <header class="section-header" style="margin-bottom:1.25rem;">
      <div>
        <h3>Edit Affiliate Program</h3>
        <p class="muted">Changes save directly to the dashboard YAML and rebuild.</p>
      </div>
      <div style="display:flex;gap:0.5rem;align-items:center;">
        <span class="priority-save-status" id="aff-save-status"></span>
        <button class="btn btn-secondary btn-sm" onclick="hideAffEdit()">Cancel</button>
        <button class="btn btn-sm" onclick="saveAffEdit()">💾 Save</button>
      </div>
    </header>

    <div class="aff-edit-grid">
      <div class="aff-edit-field">
        <label>Program name</label>
        <input type="text" id="aff-program_name" value="{{ partner.affiliate.program_name or '' }}" placeholder="e.g. Webdezigns White-Label Referral" />
      </div>
      <div class="aff-edit-field">
        <label>Status</label>
        <select id="aff-status">
          <option value="active"{% if partner.affiliate.status == 'active' %} selected{% endif %}>✓ Active</option>
          <option value="pending"{% if partner.affiliate.status == 'pending' %} selected{% endif %}>⏳ Pending</option>
          <option value="not_applied"{% if partner.affiliate.status == 'not_applied' or not partner.affiliate.status %} selected{% endif %}>→ Not applied</option>
        </select>
      </div>
      <div class="aff-edit-field">
        <label>Commission type</label>
        <select id="aff-commission_type" onchange="toggleCommissionFields()">
          <option value="percentage"{% if partner.affiliate.commission_type == 'percentage' %} selected{% endif %}>Percentage %</option>
          <option value="flat"{% if partner.affiliate.commission_type == 'flat' %} selected{% endif %}>Flat fee $</option>
        </select>
      </div>
      <div class="aff-edit-field" id="aff-pct-field"{% if partner.affiliate.commission_type == 'flat' %} style="display:none"{% endif %}>
        <label>Commission %</label>
        <input type="number" id="aff-commission_pct" value="{{ partner.affiliate.commission_pct or '' }}" placeholder="e.g. 20" min="0" max="100" step="0.5" />
      </div>
      <div class="aff-edit-field" id="aff-flat-field"{% if partner.affiliate.commission_type != 'flat' %} style="display:none"{% endif %}>
        <label>Flat fee per lead ($)</label>
        <input type="number" id="aff-commission_flat" value="{{ partner.affiliate.commission_flat or '' }}" placeholder="e.g. 500" min="0" />
      </div>
      <div class="aff-edit-field">
        <label>Commission label (display text)</label>
        <input type="text" id="aff-commission" value="{{ partner.affiliate.commission or '' }}" placeholder="e.g. $500 per referred client" />
      </div>
      <div class="aff-edit-field">
        <label>Avg deal size ($)</label>
        <input type="number" id="aff-avg_deal_size" value="{{ partner.affiliate.avg_deal_size or '' }}" placeholder="e.g. 2000" min="0" />
      </div>
      <div class="aff-edit-field">
        <label>Est. monthly leads</label>
        <input type="number" id="aff-monthly_leads" value="{{ partner.affiliate.monthly_leads or '' }}" placeholder="e.g. 4" min="0" oninput="recalcPotential()" />
      </div>
      <div class="aff-edit-field">
        <label>Est. monthly revenue ($) <span class="muted" style="font-weight:400;">(auto-calculated or override)</span></label>
        <input type="number" id="aff-monthly_potential" value="{{ partner.affiliate.monthly_potential or '' }}" placeholder="Auto" min="0" />
      </div>
      <div class="aff-edit-field aff-edit-full">
        <label>Notes</label>
        <textarea id="aff-notes" rows="3" placeholder="Internal notes about this program…">{{ partner.affiliate.notes or '' }}</textarea>
      </div>
      <div class="aff-edit-field">
        <label>Affiliate / program page URL</label>
        <input type="url" id="aff-affiliate_url" value="{{ partner.affiliate.affiliate_url or '' }}" placeholder="https://…" />
      </div>
      <div class="aff-edit-field">
        <label>Sign-up / apply URL</label>
        <input type="url" id="aff-signup_url" value="{{ partner.affiliate.signup_url or '' }}" placeholder="https://…" />
      </div>
    </div>
  </div>
</section>

<section class="partner-projects">
  <header class="section-header">
    <div>
      <h3>Projects with {{ partner.name }}</h3>
      <p class="muted">{{ partner.projectCount }} active initiative{% if partner.projectCount != 1 %}s{% endif %}</p>
    </div>
    <div class="search-field">
      <label for="search-{{ partner.slug }}" class="sr-only">Search {{ partner.name }} projects</label>
      <input id="search-{{ partner.slug }}" type="search" placeholder="Search projects" data-search-input="partner-projects-{{ partner.slug }}" />
      <small class="muted" data-search-count="partner-projects-{{ partner.slug }}"></small>
    </div>
  </header>
  <div class="grid project-grid" data-search-list="partner-projects-{{ partner.slug }}">
    {% for project in projects %}
    <article class="card" data-search-item="partner-projects-{{ partner.slug }}" data-search-text="{{ (project.name + ' ' + (project.summary or '') + ' ' + (project.owner or '') + ' ' + (project.stage or '')) | lower }}">
      <div class="card-header">
        <div>
          <h3>{{ project.name }}</h3>
          <p class="muted">{{ project.summary }}</p>
        </div>
        <span class="status-pill">{{ project.stage }}</span>
      </div>
      <dl class="meta">
        <div><dt>Owner</dt><dd>{{ project.owner }}</dd></div>
        <div><dt>Status</dt><dd>{{ project.status }}</dd></div>
        <div><dt>Last update</dt><dd>{{ project.lastUpdate | date('MMM d, yyyy') }}</dd></div>
      </dl>
      <div class="links">
        {% if project.previewUrl %}<a href="{{ project.previewUrl }}" target="_blank">Preview</a>{% endif %}
        {% if project.repoUrl %}<a href="{{ project.repoUrl }}" target="_blank">Repo</a>{% endif %}
      </div>
    </article>
    {% else %}
    <p class="muted">No linked projects yet.</p>
    {% endfor %}
  </div>
  <p class="empty-state" data-search-empty="partner-projects-{{ partner.slug }}">No projects match that search.</p>
</section>

<!-- ── Notes & Transcripts (loaded dynamically from Notion) ────────────── -->
<section class="notion-activity" id="partner-notion-activity">
  <div class="section-header">
    <div>
      <h3>Notes &amp; Call History</h3>
      <p class="muted" id="partner-activity-subtitle">Loading…</p>
    </div>
  </div>

  <!-- Submit a note (internal team only) -->
  <div class="note-form-wrap">
    <details class="note-form-toggle">
      <summary class="btn btn-secondary">+ Add a note</summary>
      <form class="note-form" id="partner-note-form" onsubmit="submitNote(event, '{{ partner.slug }}', 'partner')">
        <textarea id="partner-note-text" placeholder="Write your note…" rows="4" required></textarea>
        <div class="note-form-footer">
          <input type="text" id="partner-note-author" placeholder="Your name (optional)" />
          <button type="submit" class="btn" id="partner-note-submit-btn">Save note</button>
        </div>
        <p class="note-form-status muted" id="partner-note-status" style="display:none"></p>
      </form>
    </details>
  </div>

  <!-- Notes list -->
  <div id="partner-notes-section" style="display:none">
    <h4 class="activity-group-label">Notes</h4>
    <div id="partner-notes-list" class="activity-list"></div>
  </div>

  <!-- Transcripts list -->
  <div id="partner-transcripts-section" style="display:none">
    <h4 class="activity-group-label">Call Transcripts</h4>
    <div id="partner-transcripts-list" class="activity-list"></div>
  </div>

  <p class="muted" id="partner-activity-empty" style="display:none">No notes or calls recorded yet.</p>
</section>

<script>
var PARTNER_ID   = '{{ partner.id }}';
var ENTITY_TYPE  = 'partner';

// ── Affiliate edit toggle ─────────────────────────────────────────────
function showAffEdit() {
  document.getElementById('aff-view').style.display = 'none';
  document.getElementById('aff-edit').style.display = '';
}
function hideAffEdit() {
  document.getElementById('aff-edit').style.display = 'none';
  document.getElementById('aff-view').style.display = '';
}
function toggleCommissionFields() {
  var type = document.getElementById('aff-commission_type').value;
  document.getElementById('aff-pct-field').style.display  = type === 'percentage' ? '' : 'none';
  document.getElementById('aff-flat-field').style.display = type === 'flat' ? '' : 'none';
  recalcPotential();
}
function recalcPotential() {
  var type    = document.getElementById('aff-commission_type').value;
  var leads   = parseFloat(document.getElementById('aff-monthly_leads').value) || 0;
  var pct     = parseFloat(document.getElementById('aff-commission_pct').value) || 0;
  var flat    = parseFloat(document.getElementById('aff-commission_flat').value) || 0;
  var deal    = parseFloat(document.getElementById('aff-avg_deal_size').value) || 0;
  var potEl   = document.getElementById('aff-monthly_potential');
  if (!potEl.value || potEl.dataset.autoCalc === 'true') {
    var calc = type === 'flat' ? Math.round(flat * leads) : Math.round(pct / 100 * deal * leads);
    if (calc > 0) { potEl.value = calc; potEl.dataset.autoCalc = 'true'; }
  }
}

async function saveAffEdit() {
  var statusEl = document.getElementById('aff-save-status');
  statusEl.textContent = '⟳ Saving…';
  statusEl.className = 'priority-save-status saving';

  var type = document.getElementById('aff-commission_type').value;
  var pct  = parseFloat(document.getElementById('aff-commission_pct').value)  || null;
  var flat = parseFloat(document.getElementById('aff-commission_flat').value) || null;
  var leads = parseFloat(document.getElementById('aff-monthly_leads').value) || null;
  var deal  = parseFloat(document.getElementById('aff-avg_deal_size').value) || null;
  var pot   = parseFloat(document.getElementById('aff-monthly_potential').value) || null;
  if (!pot && leads && (pct || flat)) {
    pot = type === 'flat' ? Math.round(flat * leads) : Math.round(pct / 100 * deal * leads);
  }

  var updates = {
    'affiliate.program_name':    document.getElementById('aff-program_name').value.trim() || null,
    'affiliate.status':          document.getElementById('aff-status').value,
    'affiliate.commission_type': type,
    'affiliate.commission':      document.getElementById('aff-commission').value.trim() || null,
    'affiliate.commission_pct':  type === 'percentage' ? pct : null,
    'affiliate.commission_flat': type === 'flat' ? flat : null,
    'affiliate.avg_deal_size':   deal,
    'affiliate.monthly_leads':   leads,
    'affiliate.monthly_potential': pot,
    'affiliate.notes':           document.getElementById('aff-notes').value.trim() || null,
    'affiliate.affiliate_url':   document.getElementById('aff-affiliate_url').value.trim() || null,
    'affiliate.signup_url':      document.getElementById('aff-signup_url').value.trim() || null,
    'affiliate.active':          document.getElementById('aff-status').value === 'active'
  };

  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ entityType: ENTITY_TYPE, entityId: PARTNER_ID, updates: updates })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Saved! Rebuilding…';
      statusEl.className = 'priority-save-status saved';
      // Update view mode fields
      refreshAffView(updates, pot);
      setTimeout(function() { hideAffEdit(); statusEl.textContent = ''; }, 2500);
    } else {
      statusEl.textContent = '✗ Error: ' + (d.error || 'unknown');
      statusEl.className = 'priority-save-status error';
    }
  } catch(e) {
    statusEl.textContent = '✗ Network error';
    statusEl.className = 'priority-save-status error';
  }
}

function refreshAffView(updates, pot) {
  // Refresh the static view with new values without requiring page reload
  var viewEl = document.getElementById('aff-view');
  var potEl  = document.getElementById('aff-view-potential');
  if (potEl && pot) potEl.textContent = '$' + pot;
  var notesEl = document.getElementById('aff-view-notes');
  if (notesEl && updates['affiliate.notes']) notesEl.textContent = updates['affiliate.notes'];
}

// ── Load partner notes + transcripts from Notion API ────────────────────
(function loadPartnerNotionActivity() {
  var slug = '{{ partner.slug }}';
  fetch('/api/notion-partners?slug=' + encodeURIComponent(slug))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.lastCall) {
        document.getElementById('partner-last-call-val').textContent = data.lastCall;
        document.getElementById('partner-call-stats-row').style.display = '';
      }
      if (data.callCount) {
        document.getElementById('partner-call-count-val').textContent = data.callCount;
        document.getElementById('partner-call-count-row').style.display = '';
      }

      var notes = data.notes || [];
      var transcripts = data.transcripts || [];
      var total = notes.length + transcripts.length;

      document.getElementById('partner-activity-subtitle').textContent =
        total === 0 ? 'No activity yet' :
        notes.length + ' note' + (notes.length !== 1 ? 's' : '') +
        ' · ' + transcripts.length + ' call' + (transcripts.length !== 1 ? 's' : '');

      if (total === 0) {
        document.getElementById('partner-activity-empty').style.display = '';
        return;
      }

      if (notes.length > 0) {
        var notesList = document.getElementById('partner-notes-list');
        notes.forEach(function(note) { notesList.appendChild(buildNoteCard(note)); });
        document.getElementById('partner-notes-section').style.display = '';
      }

      if (transcripts.length > 0) {
        var txList = document.getElementById('partner-transcripts-list');
        transcripts.forEach(function(tx) { txList.appendChild(buildTranscriptCard(tx)); });
        document.getElementById('partner-transcripts-section').style.display = '';
      }
    })
    .catch(function(err) {
      document.getElementById('partner-activity-subtitle').textContent = 'Could not load activity';
      console.warn('Partner Notion activity load error:', err);
    });
})();

function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function buildNoteCard(note) {
  var el = document.createElement('div');
  el.className = 'activity-card note-card';
  var author = note.author ? ' <span class="note-author">by ' + esc(note.author) + '</span>' : '';
  el.innerHTML =
    '<div class="activity-card-header">' +
      '<span class="activity-icon">📝</span>' +
      '<span class="activity-date">' + esc(note.date || '') + author + '</span>' +
    '</div>' +
    '<div class="activity-body">' +
      note.content.map(function(c) { return '<p>' + esc(c) + '</p>'; }).join('') +
    '</div>';
  return el;
}

function buildTranscriptCard(tx) {
  var el = document.createElement('details');
  el.className = 'activity-card transcript-card';
  var title = esc(tx.title || '');
  var body = tx.content.map(function(c) { return '<p>' + esc(c) + '</p>'; }).join('');
  el.innerHTML =
    '<summary class="activity-card-header">' +
      '<span class="activity-icon">📞</span>' +
      '<span class="activity-date">' + esc(tx.date || '') + '</span>' +
      '<span class="activity-title">' + title + '</span>' +
      '<span class="activity-chevron">▸</span>' +
    '</summary>' +
    '<div class="activity-body transcript-body">' + (body || '<p class="muted">No transcript content.</p>') + '</div>';
  return el;
}

// ── Submit note (partner page) ──────────────────────────────────────────
async function submitNote(event, slug, dbType) {
  event.preventDefault();
  var prefix = dbType === 'partner' ? 'partner-' : '';
  var text = document.getElementById(prefix + 'note-text').value.trim();
  var author = document.getElementById(prefix + 'note-author').value.trim();
  var btn = document.getElementById(prefix + 'note-submit-btn');
  var status = document.getElementById(prefix + 'note-status');
  if (!text) return;

  btn.disabled = true;
  btn.textContent = 'Saving…';
  status.style.display = 'none';

  var endpoint = dbType === 'partner' ? '/api/notion-partners' : '/api/notion-clients';
  try {
    var res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: slug, text: text, author: author || undefined, type: 'note' })
    });
    if (res.ok) {
      status.textContent = '✅ Note saved to Notion.';
      status.style.color = 'var(--accent)';
      document.getElementById(prefix + 'note-text').value = '';
      var notesList = document.getElementById(prefix + 'notes-list');
      var today = new Date().toISOString().split('T')[0];
      var fakeNote = { date: today, author: author || '', content: [text] };
      notesList.prepend(buildNoteCard(fakeNote));
      document.getElementById(prefix + 'notes-section').style.display = '';
    } else {
      status.textContent = '⚠️ Failed to save. Please try again.';
      status.style.color = '#fdb874';
    }
  } catch(e) {
    status.textContent = '⚠️ Network error. Please try again.';
    status.style.color = '#fdb874';
  }
  status.style.display = '';
  btn.disabled = false;
  btn.textContent = 'Save note';
}
</script>
