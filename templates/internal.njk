<div class="workspace">
  <section class="workspace-main">
    <header class="section-header">
      <div>
        <h2>Active builds</h2>
        <p class="muted">{{ stats.activeProjects }} projects tracked across {{ stats.clientCount }} clients.</p>
      </div>
      <div class="section-actions">
        <div class="stat-chips">
          <span class="chip">Open requests: {{ stats.openRequests }}</span>
          <span class="chip">Last sync: {{ generatedAt | default('—') }}</span>
        </div>
        <div class="search-field">
          <label for="project-search" class="sr-only">Search projects</label>
          <input id="project-search" type="search" placeholder="Search projects" data-search-input="projects" />
          <small class="muted" data-search-count="projects"></small>
        </div>
      </div>
    </header>
    <div class="grid project-grid" data-search-list="projects">
    {% for project in projects %}
      <article class="card{% if project.priority %} priority-{{ project.priority }}{% endif %}"
               data-portal="./clients/{{ project.client.slug }}.html"
               data-search-item="projects"
               data-search-text="{{ (project.name + ' ' + (project.summary or '') + ' ' + (project.owner or '') + ' ' + (project.client.name or '') + ' ' + (project.stage or '') + ' ' + (project.status or '')) | lower }}">
        <div class="card-header">
          <div>
            <div class="card-title-row">
              <h2>{{ project.name }}</h2>
              {% if project.priority == 'high' %}
                <span class="priority-badge priority-badge-high" title="High priority">★</span>
              {% endif %}
            </div>
            <p class="muted">{{ project.summary }}</p>
          </div>
          <span class="status-pill {{ project.stage | lower | replace(' ', '-') }}">{{ project.stage }}</span>
        </div>
        {% if project.thumbnailUrl %}
        <div class="thumb-wrapper">
          <img class="site-thumb" src="{{ project.thumbnailUrl }}" alt="Preview of {{ project.name }}">
        </div>
        {% endif %}
        <dl class="meta">
          <div><dt>Owner</dt><dd>{{ project.owner }}</dd></div>
          <div><dt>Client</dt><dd>{{ project.client.name }}</dd></div>
          <div><dt>Status</dt><dd>{{ project.status }}</dd></div>
          <div><dt>Last update</dt><dd>{{ project.lastUpdate | date('MMM d, yyyy') }}</dd></div>
        </dl>
        <div class="links">
          {% if project.previewUrl %}<a href="{{ project.previewUrl }}" target="_blank" data-noportal>Preview</a>{% endif %}
          {% if project.repoUrl %}<a href="{{ project.repoUrl }}" target="_blank" data-noportal>Repo</a>{% endif %}
          {% if project.memoCount > 0 %}
            {% if project.voiceMemos[0].notion_url %}
              <a href="{{ project.voiceMemos[0].notion_url }}" target="_blank" data-noportal>🎙️ {{ project.memoCount }} memo{% if project.memoCount != 1 %}s{% endif %}</a>
            {% else %}
              <span class="muted">🎙️ {{ project.memoCount }} memo{% if project.memoCount != 1 %}s{% endif %}</span>
            {% endif %}
          {% endif %}
        </div>
      </article>
    {% endfor %}
    </div>
    <p class="empty-state" data-search-empty="projects">No projects match that search.</p>
  </section>
  <aside class="workspace-sidebar">
    <section class="panel panel-chat">
      <header class="chat-tab-header">
        <div class="chat-tabs">
          <button class="chat-tab active" data-chat="atlas" onclick="switchChat('atlas', this)">Atlas</button>
          <button class="chat-tab" data-chat="agis" onclick="switchChat('agis', this)">AGIS</button>
        </div>
        <p class="muted" id="chatSubtitle">Give Atlas tasks directly</p>
      </header>
      <div class="chat-messages" id="chatMessages">
        <p class="chat-empty muted">Loading messages…</p>
      </div>
      <form class="chat-form" id="chatForm" onsubmit="return false;">
        <input
          type="text"
          id="chatInput"
          class="chat-input"
          placeholder="Type a task or message…"
          autocomplete="off"
        />
        <button type="submit" class="btn chat-send" id="chatSend">Send</button>
      </form>
    </section>

    <section class="panel">
      <header>
        <h3>Clients</h3>
        <p class="muted">Open a portal</p>
      </header>
      <ul class="client-list">
        {% for client in clients %}
          <li>
            <a href="./{{ client.portalPath }}" target="_blank">{{ client.name }}</a>
            <span class="muted">{{ client.projectCount }} project{% if client.projectCount != 1 %}s{% endif %}</span>
          </li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Open requests</h3>
        <p class="muted">Newest first</p>
      </header>
      <ul class="request-list">
        {% for request in requests %}
          <li>
            <div class="request-title">{{ request.title }}</div>
            <div class="request-meta">
              <span>{{ request.client.name if request.client else 'Unknown client' }}</span>
              <span>•</span>
              <span>{{ request.status }}</span>
              <span>•</span>
              <span>{{ request.priority }} priority</span>
            </div>
            <p class="muted">{{ request.summary }}</p>
            <div class="request-footer">
              <span>Owner: {{ request.owner }}</span>
              <span>{{ request.submittedAtFormatted }}</span>
            </div>
          </li>
        {% else %}
          <li class="muted">No requests queued.</li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Recent voice memos</h3>
        <p class="muted">Auto-transcribed recordings</p>
      </header>
      <ul class="activity-list">
        {% for memo in recentMemos %}
          <li>
            <strong>
              {% if memo.notion_url %}<a href="{{ memo.notion_url }}" target="_blank">{{ memo.title }}</a>
              {% else %}{{ memo.title }}{% endif %}
            </strong>
            <p>{{ memo.summary | truncate(80) }}</p>
            <span class="muted">
              {{ memo.date | date('MMM d, h:mm a') }}
              {% if memo.project_match %} · {{ memo.project_match }}{% endif %}
              · <span class="status-pill {{ memo.type }}">{{ memo.type }}</span>
            </span>
          </li>
        {% else %}
          <li class="muted">No voice memos processed yet.</li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Subagent activity</h3>
        <p class="muted">Pulse feed</p>
      </header>
      <ul class="activity-list">
        {% for entry in settings.subagentActivity or [] %}
          <li>
            <strong>{{ entry.name }}</strong>
            <p>{{ entry.detail }}</p>
            <span class="muted">{{ entry.timestamp | date('MMM d, h:mm a') }}</span>
          </li>
        {% else %}
          <li class="muted">No activity logged.</li>
        {% endfor %}
      </ul>
    </section>
  </aside>
</div>
