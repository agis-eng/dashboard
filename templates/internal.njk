<div class="workspace">
  <section class="workspace-main">
    <header class="section-header">
      <div>
        <h2>Active builds</h2>
        <p class="muted">{{ stats.activeProjects }} projects tracked across {{ stats.clientCount }} clients.</p>
      </div>
      <div class="section-actions">
        <div class="stat-chips">
          <span class="chip">Open requests: {{ stats.openRequests }}</span>
          <span class="chip">Last sync: {{ generatedAt | default('—') }}</span>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openNewProjectModal()" data-noportal>+ New Project</button>
        <div class="search-field">
          <label for="project-search" class="sr-only">Search projects</label>
          <input id="project-search" type="search" placeholder="Search projects" data-search-input="projects" />
          <small class="muted" data-search-count="projects"></small>
        </div>
      </div>
    </header>

    {# ── Stage filter chips ── #}
    <div class="stage-filters" id="stage-filters" data-noportal>
      <button class="stage-chip active" data-stage="all"        onclick="filterStage('all', this)">All <span class="stage-count" id="sc-all"></span></button>
      <button class="stage-chip"        data-stage="lead"       onclick="filterStage('lead', this)">Lead</button>
      <button class="stage-chip"        data-stage="client"     onclick="filterStage('client', this)">Client</button>
      <button class="stage-chip"        data-stage="internal"   onclick="filterStage('internal', this)">Internal</button>
      <button class="stage-chip"        data-stage="contractor" onclick="filterStage('contractor', this)">Contractor</button>
      <button class="stage-chip"        data-stage="paused"     onclick="filterStage('paused', this)">Paused</button>
      <button class="stage-chip"        data-stage="done"       onclick="filterStage('done', this)">Done</button>
    </div>

    <div class="grid project-grid" data-search-list="projects">
    {% for project in projects %}
      <article class="card{% if project.priority %} priority-{{ project.priority }}{% endif %}"
               data-portal="./clients/{{ project.client.slug }}.html"
               data-search-item="projects"
               data-stage="{{ project.stage | lower | replace(' ', '-') }}"
               data-search-text="{{ (project.name + ' ' + (project.summary or '') + ' ' + (project.owner or '') + ' ' + (project.client.name or '') + ' ' + (project.stage or '') + ' ' + (project.status or '')) | lower }}">
        <div class="card-header">
          <div>
            <div class="card-title-row">
              <h2>{{ project.name }}</h2>
              {% if project.priority == 'high' %}
                <span class="priority-badge priority-badge-high" title="High priority">★</span>
              {% endif %}
            </div>
            <p class="muted">{{ project.summary }}</p>
          </div>
          <span class="status-pill {{ project.stage | lower | replace(' ', '-') }}">{{ project.stage }}</span>
        </div>
        {% if project.thumbnailUrl %}
        <div class="thumb-wrapper">
          <img class="site-thumb" src="{{ project.thumbnailUrl }}" alt="Preview of {{ project.name }}">
        </div>
        {% endif %}
        <dl class="meta">
          <div><dt>Owner</dt><dd>{{ project.owner }}</dd></div>
          <div><dt>Client</dt><dd>{{ project.client.name }}</dd></div>
          <div><dt>Status</dt><dd>{{ project.status }}</dd></div>
          <div><dt>Last update</dt><dd>{{ project.lastUpdate | date('MMM d, yyyy') }}</dd></div>
        </dl>
        <div class="links">
          {% if project.previewUrl %}<a href="{{ project.previewUrl }}" target="_blank" data-noportal>Preview</a>{% endif %}
          {% if project.repoUrl %}<a href="{{ project.repoUrl }}" target="_blank" data-noportal>Repo</a>{% endif %}
          {% if project.memoCount > 0 %}
            {% if project.voiceMemos[0].notion_url %}
              <a href="{{ project.voiceMemos[0].notion_url }}" target="_blank" data-noportal>🎤 {{ project.memoCount }} memo{% if project.memoCount != 1 %}s{% endif %}</a>
            {% else %}
              <span class="muted">🎤 {{ project.memoCount }} memo{% if project.memoCount != 1 %}s{% endif %}</span>
            {% endif %}
          {% endif %}
          {% if project.callCount > 0 %}
            <span class="call-chip">📞 {{ project.callCount }} call{% if project.callCount != 1 %}s{% endif %}</span>
          {% endif %}
          {% if project.brain %}
            {% set brainTotal = ((project.brain.links or []) | length) + ((project.brain.notes or []) | length) %}
            {% if brainTotal > 0 %}
              <span class="brain-chip" title="{{ (project.brain.links or []) | length }} link(s), {{ (project.brain.notes or []) | length }} note(s)">🧠 {{ brainTotal }}</span>
            {% endif %}
          {% endif %}
        </div>
        <div class="priority-control" onclick="event.stopPropagation()" data-noportal>
          <select class="priority-select"
                  data-entity-type="project"
                  data-entity-id="{{ project.id }}"
                  onchange="updatePriority(this)"
                  onclick="event.stopPropagation()">
            <option value="">— Priority —</option>
            <option value="high"{% if project.priority == 'high' %} selected{% endif %}>★ High</option>
            <option value="medium"{% if project.priority == 'medium' %} selected{% endif %}>◆ Medium</option>
            <option value="low"{% if project.priority == 'low' %} selected{% endif %}>○ Low</option>
          </select>
          <span class="priority-save-status" id="ps-{{ project.id }}"></span>
          <button class="btn btn-ghost btn-sm edit-btn" onclick="openProjectEditor(this, event)" data-noportal
                  data-id="{{ project.id }}"
                  data-name="{{ project.name }}"
                  data-status="{{ project.status }}"
                  data-summary="{{ project.summary }}"
                  data-owner="{{ project.owner }}"
                  data-stage="{{ project.stage }}"
                  data-preview="{{ project.previewUrl }}"
                  data-repo="{{ project.repoUrl }}"
                  data-contacts="{{ (project.contacts or []) | dump | escape }}"
                  data-brain-links="{{ (project.brain.links if project.brain else []) | dump | escape }}"
                  data-brain-notes="{{ (project.brain.notes if project.brain else []) | dump | escape }}">
            ✏️ Edit
          </button>
          <button class="btn btn-ghost btn-sm archive-btn" onclick="archiveProject(this, event)" data-noportal
                  data-id="{{ project.id }}"
                  data-name="{{ project.name }}">
            🗑 Archive
          </button>
        </div>

        {# ── Inline editor panel ── #}
        <div class="project-editor" id="editor-{{ project.id }}" style="display:none" data-noportal data-project-id="{{ project.id }}" onclick="event.stopPropagation()">
          <div class="editor-grid">
            <div class="editor-field editor-full">
              <label>Project name</label>
              <input type="text" class="ef-name" placeholder="Project name">
            </div>
            <div class="editor-field editor-full">
              <label>Client</label>
              <select class="ef-client" data-current="{{ project.clientId }}">
                <option value="atlas">— Internal / TBD —</option>
                {% for client in clients | sort(attribute='name') %}
                <option value="{{ client.id }}"{% if project.clientId == client.id %} selected{% endif %}>{{ client.name }}</option>
                {% endfor %}
                <option value="__new__">＋ New client…</option>
              </select>
              <input type="text" class="ef-new-client" placeholder="New client name" style="display:none;margin-top:0.4rem">
            </div>
            <div class="editor-field">
              <label>Owner</label>
              <input type="text" class="ef-owner" placeholder="Owner">
            </div>
            <div class="editor-field">
              <label>Stage</label>
              <select class="ef-stage">
                <option value="Lead">Lead</option>
                <option value="Client">Client</option>
                <option value="Internal">Internal</option>
                <option value="Contractor">Contractor</option>
                <option value="Paused">Paused</option>
                <option value="Done">Done</option>
              </select>
            </div>
            <div class="editor-field editor-full">
              <label>Status / summary</label>
              <input type="text" class="ef-status" placeholder="One-line status">
            </div>
            <div class="editor-field">
              <label>Preview URL</label>
              <input type="url" class="ef-preview" placeholder="https://">
            </div>
            <div class="editor-field">
              <label>Repo URL</label>
              <input type="url" class="ef-repo" placeholder="https://github.com/...">
            </div>
          </div>

          <div class="editor-contacts-section">
            <label class="editor-contacts-label">Contacts</label>
            <div class="editor-contacts-list" id="cl-{{ project.id }}"></div>
            <button type="button" class="btn btn-ghost btn-sm" onclick="addContactRow('{{ project.id }}')">+ Add contact</button>
          </div>

          {# ── Project Brain section ── #}
          <details class="brain-section" id="brain-{{ project.id }}">
            <summary class="brain-toggle">🧠 Project Brain <span class="brain-badge" id="bb-{{ project.id }}"></span></summary>
            <div class="brain-panel">
              <div class="brain-links-section">
                <div class="brain-sub-header">
                  <span class="brain-sub-title">🔗 Links &amp; resources</span>
                  <button type="button" class="btn btn-ghost btn-sm" onclick="addBrainLink('{{ project.id }}')">+ Add link</button>
                </div>
                <div class="brain-links-list" id="bl-{{ project.id }}"></div>
              </div>
              <div class="brain-notes-section">
                <div class="brain-sub-header">
                  <span class="brain-sub-title">📝 Notes &amp; context</span>
                  <div class="brain-add-btns">
                    <button type="button" class="btn btn-ghost btn-sm" onclick="addBrainNote('{{ project.id }}')">+ Add note</button>
                    <label class="btn btn-ghost btn-sm brain-upload-label">
                      📎 Upload file
                      <input type="file" accept=".txt,.md,.html,.csv,.json" style="display:none" onchange="uploadBrainFile(this, '{{ project.id }}')">
                    </label>
                  </div>
                </div>
                <div class="brain-notes-list" id="bn-{{ project.id }}"></div>
                <p class="brain-hint muted">Supports .txt, .md, .html, .csv · Paste any text as a note</p>
              </div>
            </div>
          </details>

          <div class="editor-actions">
            <button class="btn btn-primary btn-sm" onclick="saveProjectEditor('{{ project.id }}', this)">Save changes</button>
            <button class="btn btn-ghost btn-sm" onclick="closeProjectEditor('{{ project.id }}')">Cancel</button>
            <span class="editor-save-status" id="es-{{ project.id }}"></span>
          </div>
        </div>
      </article>
    {% endfor %}
    </div>
    <p class="empty-state" data-search-empty="projects">No projects match that search.</p>
  </section>

  {# ── Unmatched Calls Review Queue ── #}
  {% if unmatchedCallGroups and unmatchedCallGroups.length %}
  <section class="review-queue" id="review-queue">
    <header class="section-header">
      <div>
        <h2>📋 Call Review Queue</h2>
        <p class="muted">{{ unmatchedCallGroups.length }} named meeting group{% if unmatchedCallGroups.length != 1 %}s{% endif %} without a project — review and create stubs as needed.</p>
      </div>
    </header>
    <div class="queue-groups">
      {% for group in unmatchedCallGroups %}
      <details class="queue-group" id="qg-{{ loop.index }}">
        <summary class="queue-group-header">
          <span class="queue-icon">📞</span>
          <span class="queue-name">{{ group.name }}</span>
          <span class="queue-meta muted">{{ group.count }} call{% if group.count != 1 %}s{% endif %} · Last: {{ group.lastDate }}</span>
          <span class="queue-chevron">▸</span>
        </summary>
        <div class="queue-group-body">
          <div class="queue-call-list">
            {% for call in group.calls %}
            <div class="queue-call-item">
              <span class="call-date">{{ call.date }}</span>
              <span class="call-title">{{ call.title }}</span>
              {% if call.key_takeaways and call.key_takeaways.length %}
              <ul class="call-list queue-takeaways">
                {% for kt in call.key_takeaways %}{% if loop.index <= 3 %}<li>{{ kt }}</li>{% endif %}{% endfor %}
              </ul>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          <div class="queue-actions">
            <button class="btn btn-primary btn-sm" onclick="openCreateProjectModal({{ loop.index }}, {{ group.name | dump }}, {{ group.recordingIds | dump }})">
              + Create project stub
            </button>
            <div class="queue-attach">
              <select class="queue-attach-select" id="qa-{{ loop.index }}">
                <option value="">↗ Attach to existing project…</option>
                {% for p in projects | sort(attribute='name') %}
                <option value="{{ p.id }}">{{ p.name }}</option>
                {% endfor %}
              </select>
              <button class="btn btn-ghost btn-sm" onclick="attachCallsToProject({{ loop.index }}, {{ group.recordingIds | dump }})">Attach</button>
              <span class="queue-attach-status" id="qas-{{ loop.index }}"></span>
            </div>
          </div>
        </div>
      </details>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  <aside class="workspace-sidebar">
    <section class="panel panel-chat">
      <header class="chat-tab-header">
        <div class="chat-tabs">
          <button class="chat-tab active" data-chat="atlas" onclick="switchChat('atlas', this)">Atlas</button>
          <button class="chat-tab" data-chat="agis" onclick="switchChat('agis', this)">AGIS</button>
        </div>
        <p class="muted" id="chatSubtitle">Give Atlas tasks directly</p>
      </header>
      <div class="chat-messages" id="chatMessages">
        <p class="chat-empty muted">Loading messages…</p>
      </div>
      <form class="chat-form" id="chatForm" onsubmit="return false;">
        <input
          type="text"
          id="chatInput"
          class="chat-input"
          placeholder="Type a task or message…"
          autocomplete="off"
        />
        <button type="submit" class="btn chat-send" id="chatSend">Send</button>
      </form>
    </section>

    <section class="panel">
      <header>
        <h3>Clients</h3>
        <p class="muted">Open a portal</p>
      </header>
      <ul class="client-list">
        {% for client in clients %}
          <li>
            <a href="./{{ client.portalPath }}" target="_blank">{{ client.name }}</a>
            <span class="muted">{{ client.projectCount }} project{% if client.projectCount != 1 %}s{% endif %}</span>
          </li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Open requests</h3>
        <p class="muted">Newest first</p>
      </header>
      <ul class="request-list">
        {% for request in requests %}
          <li>
            <div class="request-title">{{ request.title }}</div>
            <div class="request-meta">
              <span>{{ request.client.name if request.client else 'Unknown client' }}</span>
              <span>•</span>
              <span>{{ request.status }}</span>
              <span>•</span>
              <span>{{ request.priority }} priority</span>
            </div>
            <p class="muted">{{ request.summary }}</p>
            <div class="request-footer">
              <span>Owner: {{ request.owner }}</span>
              <span>{{ request.submittedAtFormatted }}</span>
            </div>
          </li>
        {% else %}
          <li class="muted">No requests queued.</li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Recent voice memos</h3>
        <p class="muted">Auto-transcribed recordings</p>
      </header>
      <ul class="activity-list">
        {% for memo in recentMemos %}
          <li>
            <strong>
              {% if memo.notion_url %}<a href="{{ memo.notion_url }}" target="_blank">{{ memo.title }}</a>
              {% else %}{{ memo.title }}{% endif %}
            </strong>
            <p>{{ memo.summary | truncate(80) }}</p>
            <span class="muted">
              {{ memo.date | date('MMM d, h:mm a') }}
              {% if memo.project_match %} · {{ memo.project_match }}{% endif %}
              · <span class="status-pill {{ memo.type }}">{{ memo.type }}</span>
            </span>
          </li>
        {% else %}
          <li class="muted">No voice memos processed yet.</li>
        {% endfor %}
      </ul>
    </section>

    <section class="panel">
      <header>
        <h3>Subagent activity</h3>
        <p class="muted">Pulse feed</p>
      </header>
      <ul class="activity-list">
        {% for entry in settings.subagentActivity or [] %}
          <li>
            <strong>{{ entry.name }}</strong>
            <p>{{ entry.detail }}</p>
            <span class="muted">{{ entry.timestamp | date('MMM d, h:mm a') }}</span>
          </li>
        {% else %}
          <li class="muted">No activity logged.</li>
        {% endfor %}
      </ul>
    </section>
  </aside>
</div>

<script>
/* ── Priority select ── */
async function updatePriority(select) {
  var entityType = select.dataset.entityType;
  var entityId   = select.dataset.entityId;
  var value      = select.value || null;
  var statusEl   = document.getElementById('ps-' + entityId);
  statusEl.textContent = '⟳';
  statusEl.className = 'priority-save-status saving';
  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ entityType: entityType, entityId: entityId, updates: { priority: value } })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Saved';
      statusEl.className = 'priority-save-status saved';
      var card = select.closest('.card');
      card.className = card.className.replace(/\bpriority-\w+\b/g, '').trim();
      if (value) card.classList.add('priority-' + value);
      var existingBadge = card.querySelector('.priority-badge');
      if (existingBadge) existingBadge.remove();
      if (value === 'high') {
        var badge = document.createElement('span');
        badge.className = 'priority-badge priority-badge-high';
        badge.title = 'High priority';
        badge.textContent = '★';
        card.querySelector('.card-title-row').appendChild(badge);
      }
      setTimeout(function() { statusEl.textContent = ''; }, 2500);
    } else {
      statusEl.textContent = '✗ Error';
      statusEl.className = 'priority-save-status error';
    }
  } catch(e) {
    statusEl.textContent = '✗ Error';
    statusEl.className = 'priority-save-status error';
  }
}

/* ── Stage filter ── */
function filterStage(stage, btn) {
  document.querySelectorAll('.stage-chip').forEach(function(c) { c.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.project-grid .card').forEach(function(card) {
    var s = card.dataset.stage || '';
    card.style.display = (stage === 'all' || s === stage) ? '' : 'none';
  });
}

/* ── New Project modal ── */
function openNewProjectModal() {
  var modal = document.getElementById('create-project-modal');
  document.getElementById('create-modal-title').textContent = 'New Project';
  document.getElementById('cp-name').value    = '';
  document.getElementById('cp-owner').value   = 'Erik';
  document.getElementById('cp-stage').value   = 'Lead';
  document.getElementById('cp-summary').value = '';
  document.getElementById('cp-preview').value = '';
  document.getElementById('cp-client').value  = 'atlas';
  document.getElementById('cp-new-client').style.display = 'none';
  document.getElementById('cp-recording-ids').value = '[]';
  document.getElementById('cp-contacts-list').innerHTML = '';
  document.getElementById('cp-status').textContent = '';
  modal.style.display = 'flex';
}

function toggleNewClientField() {
  var sel = document.getElementById('cp-client');
  var inp = document.getElementById('cp-new-client');
  if (sel) inp.style.display = sel.value === '__new__' ? 'block' : 'none';
}

function toggleEditorNewClientField(editor) {
  var sel = editor.querySelector('.ef-client');
  var inp = editor.querySelector('.ef-new-client');
  if (sel && inp) inp.style.display = sel.value === '__new__' ? 'block' : 'none';
}

/* ── Project inline editor ── */
function openProjectEditor(btn, evt) {
  evt.stopPropagation();
  var id = btn.dataset.id;
  var editor = document.getElementById('editor-' + id);
  if (!editor) return;
  // Close any other open editors
  document.querySelectorAll('.project-editor').forEach(function(e) {
    if (e !== editor) e.style.display = 'none';
  });
  // Populate fields
  editor.querySelector('.ef-name').value    = btn.dataset.name    || '';
  editor.querySelector('.ef-owner').value   = btn.dataset.owner   || '';
  editor.querySelector('.ef-status').value  = btn.dataset.status  || '';
  editor.querySelector('.ef-preview').value = btn.dataset.preview || '';
  editor.querySelector('.ef-repo').value    = btn.dataset.repo    || '';
  // Stage select
  editor.querySelector('.ef-stage').value = btn.dataset.stage || 'Lead';
  // Client select — set to current, wiring change handler
  var clientSel = editor.querySelector('.ef-client');
  if (clientSel) {
    clientSel.value = btn.dataset.id ? clientSel.dataset.current || 'atlas' : 'atlas';
    clientSel.onchange = function() { toggleEditorNewClientField(editor); };
  }
  // Contacts
  var contacts = [];
  try { contacts = JSON.parse(btn.dataset.contacts || '[]'); } catch(e) {}
  renderContactRows(id, contacts);
  // Brain data
  var brainLinks = [], brainNotes = [];
  try { brainLinks = JSON.parse(btn.dataset.brainLinks || '[]'); } catch(e) {}
  try { brainNotes = JSON.parse(btn.dataset.brainNotes || '[]'); } catch(e) {}
  renderBrainLinks(id, brainLinks);
  renderBrainNotes(id, brainNotes);
  // Auto-open brain section if it has content
  var brainDetails = document.getElementById('brain-' + id);
  if (brainDetails && (brainLinks.length || brainNotes.length)) brainDetails.open = true;
  editor.style.display = 'block';
  editor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function closeProjectEditor(id) {
  var editor = document.getElementById('editor-' + id);
  if (editor) editor.style.display = 'none';
}

function renderContactRows(projectId, contacts) {
  var list = document.getElementById('cl-' + projectId);
  if (!list) return;
  list.innerHTML = '';
  (contacts || []).forEach(function(c, i) {
    list.appendChild(makeContactRow(projectId, c, i));
  });
}

function makeContactRow(projectId, c, idx) {
  var row = document.createElement('div');
  row.className = 'contact-row';
  row.dataset.idx = idx;
  row.innerHTML =
    '<input type="text"  class="cr-name"  placeholder="Name"  value="' + esc(c.name  || '') + '">' +
    '<input type="email" class="cr-email" placeholder="Email" value="' + esc(c.email || '') + '">' +
    '<input type="tel"   class="cr-phone" placeholder="Phone" value="' + esc(c.phone || '') + '">' +
    '<input type="text"  class="cr-role"  placeholder="Role"  value="' + esc(c.role  || '') + '">' +
    '<button type="button" class="btn btn-ghost btn-sm cr-del" onclick="removeContactRow(this)">✕</button>';
  return row;
}

function esc(s) { return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

function addContactRow(projectId) {
  var list = document.getElementById('cl-' + projectId);
  if (!list) return;
  var idx = list.children.length;
  list.appendChild(makeContactRow(projectId, {}, idx));
}

function removeContactRow(btn) { btn.closest('.contact-row').remove(); }

function collectContacts(projectId) {
  var list = document.getElementById('cl-' + projectId);
  if (!list) return [];
  return Array.from(list.querySelectorAll('.contact-row'))
    .map(function(row) {
      var name  = row.querySelector('.cr-name').value.trim();
      var email = row.querySelector('.cr-email').value.trim();
      var phone = row.querySelector('.cr-phone').value.trim();
      var role  = row.querySelector('.cr-role').value.trim();
      if (!name && !email && !phone) return null;
      var c = {};
      if (name)  c.name  = name;
      if (email) c.email = email;
      if (phone) c.phone = phone;
      if (role)  c.role  = role;
      return c;
    })
    .filter(Boolean);
}

async function saveProjectEditor(id, btn) {
  var editor = document.getElementById('editor-' + id);
  var statusEl = document.getElementById('es-' + id);
  statusEl.textContent = '⟳ Saving…';
  statusEl.style.color = 'var(--muted)';
  btn.disabled = true;

  var clientSel = editor.querySelector('.ef-client');
  var clientId = clientSel ? clientSel.value : null;
  var newClientName = (clientId === '__new__') ? (editor.querySelector('.ef-new-client').value.trim() || '') : null;

  var updates = {
    name:       editor.querySelector('.ef-name').value.trim(),
    owner:      editor.querySelector('.ef-owner').value.trim(),
    stage:      editor.querySelector('.ef-stage').value,
    status:     editor.querySelector('.ef-status').value.trim(),
    previewUrl: editor.querySelector('.ef-preview').value.trim() || null,
    repoUrl:    editor.querySelector('.ef-repo').value.trim() || null,
    contacts:   collectContacts(id),
    lastUpdate: new Date().toISOString().slice(0, 10),
  };
  if (clientId && clientId !== '__new__') updates.clientId = clientId;
  if (!updates.contacts.length) delete updates.contacts;
  // Brain data
  var brainLinks = collectBrainLinks(id);
  var brainNotes = collectBrainNotes(id);
  updates['brain.links'] = brainLinks.length ? brainLinks : null;
  updates['brain.notes'] = brainNotes.length ? brainNotes : null;

  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ entityType: 'project', entityId: id, updates: updates })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Saved — rebuilding…';
      statusEl.style.color = '#4ade80';
      // Update the edit button's data attrs so re-open shows fresh data
      var editBtn = editor.previousElementSibling && editor.previousElementSibling.querySelector('.edit-btn')
                 || document.querySelector('[data-id="' + id + '"]');
      if (editBtn) {
        editBtn.dataset.name    = updates.name;
        editBtn.dataset.owner   = updates.owner;
        editBtn.dataset.stage   = updates.stage;
        editBtn.dataset.status  = updates.status;
        editBtn.dataset.preview = updates.previewUrl || '';
        editBtn.dataset.repo    = updates.repoUrl    || '';
        editBtn.dataset.contacts = JSON.stringify(updates.contacts || []);
        editBtn.dataset.brainLinks = JSON.stringify(brainLinks);
        editBtn.dataset.brainNotes = JSON.stringify(brainNotes);
        // Update visible card fields immediately
        var card = editor.closest('.card');
        if (card) {
          var h2 = card.querySelector('h2'); if (h2) h2.textContent = updates.name;
          var summ = card.querySelector('.card-header .muted'); if (summ) summ.textContent = updates.status;
          var stagePill = card.querySelector('.status-pill');
          if (stagePill) { stagePill.textContent = updates.stage; stagePill.className = 'status-pill ' + updates.stage.toLowerCase().replace(/ /g, '-'); }
          var ownerDd = card.querySelector('.meta dd'); if (ownerDd) ownerDd.textContent = updates.owner;
        }
      }
      setTimeout(function() { statusEl.textContent = ''; editor.style.display = 'none'; }, 2500);
    } else {
      statusEl.textContent = '✗ ' + (d.error || 'Error');
      statusEl.style.color = '#f87171';
    }
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.style.color = '#f87171';
  }
  btn.disabled = false;
}

/* ── Create project modal (from call queue) ── */
function openCreateProjectModal(idx, name, recordingIds) {
  var modal = document.getElementById('create-project-modal');
  document.getElementById('create-modal-title').textContent = 'Create project stub';
  modal.querySelector('#cp-name').value    = name;
  modal.querySelector('#cp-owner').value   = 'Erik';
  modal.querySelector('#cp-stage').value   = 'Lead';
  modal.querySelector('#cp-summary').value = '';
  modal.querySelector('#cp-client').value  = 'atlas';
  modal.querySelector('#cp-new-client').style.display = 'none';
  if (modal.querySelector('#cp-preview')) modal.querySelector('#cp-preview').value = '';
  modal.querySelector('#cp-recording-ids').value = JSON.stringify(recordingIds);
  document.getElementById('cp-contacts-list').innerHTML = '';
  document.getElementById('cp-status').textContent = '';
  modal.style.display = 'flex';
}


/* ── Optimistic UI: inject new project card immediately on create ── */
function injectNewProjectCard(projectId, payload) {
  var grid = document.querySelector('.project-grid');
  if (!grid) return;

  var name       = payload.name       || '';
  var summary    = payload.summary    || name;
  var owner      = payload.owner      || 'Erik';
  var stage      = payload.stage      || 'Lead';
  var clientId   = payload.clientId   || 'atlas';
  var previewUrl = payload.previewUrl || null;
  var stageSlug  = stage.toLowerCase().replace(/\s+/g, '-');
  var today      = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

  // Resolve client display name from the dropdown
  var clientSel  = document.getElementById('cp-client');
  var clientName = 'Unknown';
  if (clientSel) {
    var opt = clientSel.options[clientSel.selectedIndex];
    if (opt) clientName = opt.text;
  }

  var article = document.createElement('article');
  article.className = 'card';
  article.setAttribute('data-search-item', 'projects');
  article.setAttribute('data-stage', stageSlug);
  article.setAttribute('data-search-text',
    (name + ' ' + summary + ' ' + owner + ' ' + clientName + ' ' + stage).toLowerCase());

  article.innerHTML =
    '<div class="card-header">' +
      '<div>' +
        '<div class="card-title-row"><h2>' + esc(name) + '</h2></div>' +
        '<p class="muted">' + esc(summary) + '</p>' +
      '</div>' +
      '<span class="status-pill ' + stageSlug + '">' + esc(stage) + '</span>' +
    '</div>' +
    '<dl class="meta">' +
      '<div><dt>Owner</dt><dd>' + esc(owner) + '</dd></div>' +
      '<div><dt>Client</dt><dd>' + esc(clientName) + '</dd></div>' +
      '<div><dt>Status</dt><dd>' + esc(summary) + '</dd></div>' +
      '<div><dt>Last update</dt><dd>' + today + '</dd></div>' +
    '</dl>' +
    (previewUrl ? '<div class="links"><a href="' + esc(previewUrl) + '" target="_blank" data-noportal>Preview</a></div>' : '') +
    '<p class="muted" style="font-size:0.75rem;margin-top:0.5rem;opacity:0.6">⟳ Rebuilding — full details after next load</p>';

  // Prepend to grid so it appears at the top
  grid.insertBefore(article, grid.firstChild);

  // Wire into search filter
  var searchInput = document.querySelector('[data-search-input="projects"]');
  if (searchInput) searchInput.dispatchEvent(new Event('input'));

  // Update the subtitle count
  var subtitle = document.querySelector('.section-header .muted');
  if (subtitle) {
    var m = subtitle.textContent.match(/(\d+) projects tracked across (\d+) clients/);
    if (m) {
      subtitle.textContent = (parseInt(m[1]) + 1) + ' projects tracked across ' + m[2] + ' clients.';
    }
  }
}

function closeCreateModal() {
  document.getElementById('create-project-modal').style.display = 'none';
}

function addCpContactRow() {
  var list = document.getElementById('cp-contacts-list');
  var row = document.createElement('div');
  row.className = 'contact-row';
  row.innerHTML =
    '<input type="text"  class="cr-name"  placeholder="Name">' +
    '<input type="email" class="cr-email" placeholder="Email">' +
    '<input type="tel"   class="cr-phone" placeholder="Phone">' +
    '<input type="text"  class="cr-role"  placeholder="Role">' +
    '<button type="button" class="btn btn-ghost btn-sm" onclick="removeContactRow(this)">✕</button>';
  list.appendChild(row);
}

function collectCpContacts() {
  return Array.from(document.querySelectorAll('#cp-contacts-list .contact-row'))
    .map(function(row) {
      var name  = row.querySelector('.cr-name').value.trim();
      var email = row.querySelector('.cr-email').value.trim();
      var phone = row.querySelector('.cr-phone').value.trim();
      var role  = row.querySelector('.cr-role').value.trim();
      if (!name && !email && !phone) return null;
      var c = {};
      if (name)  c.name  = name;
      if (email) c.email = email;
      if (phone) c.phone = phone;
      if (role)  c.role  = role;
      return c;
    }).filter(Boolean);
}

async function submitCreateProject(btn) {
  var modal = document.getElementById('create-project-modal');
  var statusEl = document.getElementById('cp-status');
  var name = modal.querySelector('#cp-name').value.trim();
  if (!name) { statusEl.textContent = 'Name is required'; statusEl.style.color = '#f87171'; return; }
  btn.disabled = true;
  statusEl.textContent = '⟳ Creating…';
  statusEl.style.color = 'var(--muted)';
  var clientSel = modal.querySelector('#cp-client');
  var clientId = clientSel ? clientSel.value : 'atlas';
  var newClientName = (clientId === '__new__') ? (modal.querySelector('#cp-new-client').value.trim() || '') : null;

  var payload = {
    name:          name,
    owner:         modal.querySelector('#cp-owner').value.trim() || 'Erik',
    stage:         modal.querySelector('#cp-stage').value,
    summary:       modal.querySelector('#cp-summary').value.trim(),
    previewUrl:    (modal.querySelector('#cp-preview') || {}).value && modal.querySelector('#cp-preview').value.trim() || null,
    clientId:      (clientId !== '__new__') ? clientId : null,
    newClientName: newClientName || null,
    contacts:      collectCpContacts(),
    linkCallIds:   JSON.parse(modal.querySelector('#cp-recording-ids').value || '[]'),
  };
  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'create-project', ...payload })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Created "' + d.name + '"';
      statusEl.style.color = '#4ade80';
      injectNewProjectCard(d.id, payload);
      setTimeout(closeCreateModal, 1500);
    } else {
      statusEl.textContent = '✗ ' + (d.error || 'Error');
      statusEl.style.color = '#f87171';
      btn.disabled = false;
    }
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.style.color = '#f87171';
    btn.disabled = false;
  }
}

/* ── Attach calls to existing project (review queue) ── */
async function attachCallsToProject(idx, recordingIds) {
  var sel = document.getElementById('qa-' + idx);
  var statusEl = document.getElementById('qas-' + idx);
  var projectId = sel ? sel.value : '';
  if (!projectId) { statusEl.textContent = 'Pick a project first'; statusEl.style.color = '#f87171'; setTimeout(function(){ statusEl.textContent=''; }, 2000); return; }
  var projectName = sel.options[sel.selectedIndex].text;
  statusEl.textContent = '⟳ Linking…';
  statusEl.style.color = 'var(--muted)';
  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'link-calls', callIds: recordingIds.map(String), projectId: projectId })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ ' + d.updated + ' call' + (d.updated !== 1 ? 's' : '') + ' → ' + projectName;
      statusEl.style.color = '#4ade80';
      // Collapse and fade out the group after a moment
      var group = document.getElementById('qg-' + idx);
      if (group) { setTimeout(function() { group.style.opacity = '0.4'; }, 1500); }
    } else {
      statusEl.textContent = '✗ ' + (d.error || 'Error');
      statusEl.style.color = '#f87171';
    }
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.style.color = '#f87171';
  }
}

/* ── Archive Project ── */
async function archiveProject(btn, evt) {
  evt.stopPropagation();
  var id = btn.dataset.id;
  var name = btn.dataset.name;

  if (!confirm('Archive project "' + name + '"? This will remove it from the dashboard.')) {
    return;
  }

  try {
    var response = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'archive-project', id: id })
    });

    var result = await response.json();

    if (result.ok) {
      // Find and fade out the project card
      var card = btn.closest('.card');
      if (card) {
        card.style.transition = 'opacity 0.3s, transform 0.3s';
        card.style.opacity = '0.5';
        card.style.transform = 'scale(0.95)';

        setTimeout(function() {
          card.remove();
        }, 300);
      }

      // Show success toast
      showToast('Archived project "' + name + '"');
    } else {
      alert('Failed to archive project: ' + (result.error || 'Unknown error'));
    }
  } catch (err) {
    alert('Error archiving project: ' + err.message);
  }
}

function showToast(message) {
  // Create a simple toast notification
  var toast = document.createElement('div');
  toast.className = 'toast-notification';
  toast.textContent = message;
  toast.style.cssText = 'position:fixed;top:20px;right:20px;background:#4ade80;color:white;padding:12px 20px;border-radius:6px;z-index:9999;opacity:0;transition:opacity 0.3s;';
  document.body.appendChild(toast);

  setTimeout(function() { toast.style.opacity = '1'; }, 10);
  setTimeout(function() { toast.style.opacity = '0'; }, 3000);
  setTimeout(function() { document.body.removeChild(toast); }, 3300);
}

/* ── Brain (links + notes) ── */
function renderBrainLinks(projectId, links) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return;
  list.innerHTML = '';
  (links || []).forEach(function(l, i) { list.appendChild(makeBrainLinkRow(projectId, l, i)); });
  updateBrainBadge(projectId);
}

function renderBrainNotes(projectId, notes) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.innerHTML = '';
  (notes || []).forEach(function(n, i) { list.appendChild(makeBrainNoteRow(projectId, n, i)); });
  updateBrainBadge(projectId);
}

function makeBrainLinkRow(projectId, l, idx) {
  var row = document.createElement('div');
  row.className = 'brain-link-row';
  row.dataset.idx = idx;
  row.innerHTML =
    '<input type="url"  class="bl-url"   placeholder="https://" value="' + esc(l.url   || '') + '">' +
    '<input type="text" class="bl-label" placeholder="Label"    value="' + esc(l.label || '') + '">' +
    '<button type="button" class="btn btn-ghost btn-sm" onclick="removeBrainRow(this)">✕</button>';
  return row;
}

function makeBrainNoteRow(projectId, n, idx) {
  var row = document.createElement('div');
  row.className = 'brain-note-row';
  row.dataset.idx = idx;
  var text = typeof n === 'string' ? n : (n.text || '');
  row.innerHTML =
    '<textarea class="bn-text" placeholder="Note or context…" rows="3">' + esc(text) + '</textarea>' +
    '<button type="button" class="btn btn-ghost btn-sm" onclick="removeBrainRow(this)">✕</button>';
  return row;
}

function addBrainLink(projectId) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainLinkRow(projectId, {}, list.children.length));
}

function addBrainNote(projectId) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainNoteRow(projectId, '', list.children.length));
}

function removeBrainRow(btn) {
  var row = btn.closest('.brain-link-row, .brain-note-row');
  if (row) row.remove();
}

function collectBrainLinks(projectId) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return [];
  return Array.from(list.querySelectorAll('.brain-link-row')).map(function(row) {
    var url   = row.querySelector('.bl-url').value.trim();
    var label = row.querySelector('.bl-label').value.trim();
    if (!url) return null;
    return { url: url, label: label || url };
  }).filter(Boolean);
}

function collectBrainNotes(projectId) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return [];
  return Array.from(list.querySelectorAll('.brain-note-row')).map(function(row) {
    var text = row.querySelector('.bn-text').value.trim();
    return text || null;
  }).filter(Boolean);
}

function updateBrainBadge(projectId) {
  var badge = document.getElementById('bb-' + projectId);
  if (!badge) return;
  var linkCount = (document.getElementById('bl-' + projectId) || { children: [] }).children.length;
  var noteCount = (document.getElementById('bn-' + projectId) || { children: [] }).children.length;
  var total = linkCount + noteCount;
  badge.textContent = total > 0 ? '(' + total + ')' : '';
}

async function uploadBrainFile(input, projectId) {
  var file = input.files[0];
  if (!file) return;
  var text = await file.text();
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainNoteRow(projectId, text.slice(0, 8000), list.children.length));
  updateBrainBadge(projectId);
  input.value = '';
}

/* ── Search filter (client list) ── */
const initCardPortals = () => {
  document.querySelectorAll('[data-portal]').forEach(card => {
    card.addEventListener('click', event => {
      if (event.target.closest('[data-noportal]')) return;
      const url = card.getAttribute('data-portal');
      if (url) window.open(url, '_blank');
    });
  });
  document.querySelectorAll('[data-noportal]').forEach(link => {
    link.addEventListener('click', event => event.stopPropagation());
  });
};

const initSearchFilters = () => {
  document.querySelectorAll('[data-search-input]').forEach(input => {
    const group = input.getAttribute('data-search-input');
    const list = document.querySelector(`[data-search-list="${group}"]`);
    const items = list
      ? Array.from(list.querySelectorAll(`[data-search-item="${group}"]`))
      : Array.from(document.querySelectorAll(`[data-search-item="${group}"]`));
    if (!items.length) return;
    const emptyState = document.querySelector(`[data-search-empty="${group}"]`);
    const counter = document.querySelector(`[data-search-count="${group}"]`);
    const update = () => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;
      items.forEach(item => {
        const text = (item.getAttribute('data-search-text') || '').toLowerCase();
        const matches = !query || text.includes(query);
        item.style.display = matches ? '' : 'none';
        if (matches) visible += 1;
      });
      if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
      if (counter) {
        const total = items.length;
        counter.textContent = visible === total ? `Showing all ${total}` : `Showing ${visible} of ${total}`;
      }
    };
    input.addEventListener('input', update);
    update();
  });
};

document.addEventListener('DOMContentLoaded', () => {
  initCardPortals();
  initSearchFilters();
  initAtlasChat();
});

// ── Chat (Atlas + AGIS) ───────────────────────────────────────────────────────
var activeChat = 'atlas';
var chatState = {
  atlas: { lastUpdateId: null, rendered: new Set(), pollTimer: null },
  agis:  { lastUpdateId: null, rendered: new Set(), pollTimer: null }
};

var chatConfig = {
  atlas: { sendUrl: '/api/telegram-send',  fetchUrl: '/api/telegram-messages',  label: 'Atlas', subtitle: 'Give Atlas tasks directly' },
  agis:  { sendUrl: '/api/agis',            fetchUrl: '/api/agis',       label: 'AGIS',  subtitle: 'Talk to AGIS (Anton\'s agent)' }
};

function switchChat(name, btn) {
  activeChat = name;
  document.querySelectorAll('.chat-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  var subtitle = document.getElementById('chatSubtitle');
  if (subtitle) subtitle.textContent = chatConfig[name].subtitle;
  var container = document.getElementById('chatMessages');
  container.innerHTML = '<p class="chat-empty muted">Loading messages…</p>';
  chatState[name].rendered = new Set();
  chatState[name].lastUpdateId = null;
  document.getElementById('chatInput').placeholder = 'Message ' + chatConfig[name].label + '…';
  fetchMessages(name);
}

function initAtlasChat() {
  var form = document.getElementById('chatForm');
  var input = document.getElementById('chatInput');
  var sendBtn = document.getElementById('chatSend');
  if (!form) return;

  form.addEventListener('submit', function() {
    var text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendMessage(activeChat, text);
  });

  fetchMessages('atlas');
  setInterval(function() { fetchMessages(activeChat); }, 4000);
}

function formatTime(unixTs) {
  return new Date(unixTs * 1000).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function addBubble(chatName, msg, outgoing) {
  if (chatName !== activeChat) return;
  var state = chatState[chatName];
  if (state.rendered.has(msg.message_id)) return;
  state.rendered.add(msg.message_id);
  var container = document.getElementById('chatMessages');
  var bubble = document.createElement('div');
  bubble.className = 'chat-bubble ' + (outgoing ? 'outgoing' : 'incoming');
  bubble.innerHTML =
    '<div class="chat-bubble-text">' + msg.text.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>' +
    '<span class="chat-bubble-meta">' + (outgoing ? 'You' : msg.from) + ' · ' + formatTime(msg.date) + '</span>';
  container.appendChild(bubble);
  container.scrollTop = container.scrollHeight;
}

async function fetchMessages(chatName) {
  var state = chatState[chatName];
  var cfg = chatConfig[chatName];
  try {
    var url = state.lastUpdateId
      ? cfg.fetchUrl + '?since=' + state.lastUpdateId
      : cfg.fetchUrl;
    var r = await fetch(url);
    if (!r.ok) return;
    var data = await r.json();
    if (data.messages && data.messages.length) {
      var container = document.getElementById('chatMessages');
      var empty = container.querySelector('.chat-empty');
      if (empty) empty.remove();
      data.messages.forEach(function(msg) { addBubble(chatName, msg, false); });
      state.lastUpdateId = data.messages[data.messages.length - 1].message_id;
    }
  } catch(e) { /* ignore poll errors */ }
}

async function sendMessage(chatName, text) {
  var cfg = chatConfig[chatName];
  addBubble(chatName, { message_id: 'out-' + Date.now(), text: text, from: 'You', date: Date.now() / 1000 }, true);
  try {
    await fetch(cfg.sendUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text })
    });
  } catch(e) { /* ignore send errors */ }
}

async function archiveProject(btn, evt) {
  evt.stopPropagation();
  var id = btn.dataset.id;
  var name = btn.dataset.name;

  if (!confirm(`Are you sure you want to archive "${name}"? This will hide it from the project list.`)) {
    return;
  }

  // Disable the button and show loading state
  btn.disabled = true;
  btn.textContent = '⟳ Archiving...';

  try {
    const response = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'archive-project', id: id })
    });

    if (response.ok) {
      // Fade out and remove the project card
      var projectCard = btn.closest('article');
      if (projectCard) {
        projectCard.style.opacity = '0.5';
        projectCard.style.transition = 'opacity 0.3s';
        setTimeout(() => {
          projectCard.remove();
        }, 300);
      }

      // Show success toast
      showToast('Archived', 'success');
    } else {
      throw new Error('Archive failed');
    }
  } catch (err) {
    console.error('Archive error:', err);
    showToast('Failed to archive project', 'error');
    btn.disabled = false;
    btn.textContent = '🗑 Archive';
  }
}

function showToast(message, type) {
  // Simple toast notification
  var toast = document.createElement('div');
  toast.textContent = message;
  toast.style.cssText = `
    position: fixed;
    top: 20px;
    right: 20px;
    padding: 12px 20px;
    border-radius: 6px;
    color: white;
    font-size: 14px;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.3s;
    ${type === 'success' ? 'background: #10b981;' : 'background: #ef4444;'}
  `;
  document.body.appendChild(toast);

  // Fade in
  setTimeout(() => toast.style.opacity = '1', 10);

  // Fade out and remove
  setTimeout(() => {
    toast.style.opacity = '0';
    setTimeout(() => document.body.removeChild(toast), 300);
  }, 3000);
}
</script>

{# ── Create / Edit Project modal ── #}
<div id="create-project-modal" style="display:none" class="modal-backdrop" onclick="if(event.target===this)closeCreateModal()">
  <div class="modal">
    <header class="modal-header">
      <h2 id="create-modal-title">New Project</h2>
      <button class="modal-close" onclick="closeCreateModal()">✕</button>
    </header>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-field form-full">
          <label for="cp-name">PROJECT NAME <span class="req">*</span></label>
          <input id="cp-name" type="text" placeholder="e.g. ECHO Website Redesign" required>
        </div>
        <div class="form-field form-full">
          <label for="cp-client">CLIENT</label>
          <select id="cp-client" onchange="toggleNewClientField()">
            <option value="atlas">— Internal / TBD —</option>
            {% for client in clients | sort(attribute='name') %}
            <option value="{{ client.id }}">{{ client.name }}</option>
            {% endfor %}
            <option value="__new__">＋ New client…</option>
          </select>
          <input id="cp-new-client" type="text" placeholder="New client name" style="display:none;margin-top:0.4rem">
        </div>
        <div class="form-field">
          <label for="cp-owner">OWNER</label>
          <input id="cp-owner" type="text" value="Erik">
        </div>
        <div class="form-field">
          <label for="cp-stage">STAGE</label>
          <select id="cp-stage">
            <option value="Lead">Lead</option>
            <option value="Client">Client</option>
            <option value="Internal">Internal</option>
            <option value="Contractor">Contractor</option>
            <option value="Paused">Paused</option>
          </select>
        </div>
        <div class="form-field form-full">
          <label for="cp-summary">SUMMARY</label>
          <input id="cp-summary" type="text" placeholder="One-line description">
        </div>
        <div class="form-field form-full">
          <label for="cp-preview">PREVIEW URL <span class="optional">(optional)</span></label>
          <input id="cp-preview" type="url" placeholder="https://">
        </div>
      </div>
      <div class="form-contacts">
        <label class="form-contacts-label">CONTACTS <span class="optional">(optional)</span></label>
        <div id="cp-contacts-list"></div>
        <button type="button" class="btn btn-ghost btn-sm" onclick="addCpContactRow()">+ Add contact</button>
      </div>
      <input type="hidden" id="cp-recording-ids" value="[]">
    </div>
    <footer class="modal-footer">
      <span id="cp-status" class="form-status"></span>
      <button class="btn btn-ghost" onclick="closeCreateModal()">Cancel</button>
      <button class="btn btn-primary" onclick="submitCreateProject(this)">Create project</button>
    </footer>
  </div>
</div>
