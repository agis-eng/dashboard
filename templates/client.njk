<script>
(function() {
  var slug = '{{ client.slug }}';
  var token = localStorage.getItem('atlas_token');
  var storedSlug = localStorage.getItem('atlas_client_slug');
  if (!token || (storedSlug !== slug && storedSlug !== 'admin')) {
    window.location.href = '../login.html?redirect=' + encodeURIComponent(window.location.pathname);
    return;
  }
  fetch('/api/verify', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.valid || (data.clientSlug !== slug && data.clientSlug !== 'admin')) {
        localStorage.removeItem('atlas_token');
        localStorage.removeItem('atlas_client_slug');
        window.location.href = '../login.html?redirect=' + encodeURIComponent(window.location.pathname);
        return;
      }
      if (data.mustChangePassword) {
        window.location.href = '../change-password.html';
      }
    })
    .catch(function() {});
})();
</script>

<section class="client-info">
  <div>
    <h2>{{ client.name }}</h2>
    {% if client.summary %}<p>{{ client.summary }}</p>{% endif %}
    <dl class="contact-meta">
      {% if client.email or client.contact %}
      <div>
        <dt>Email</dt>
        <dd><a href="mailto:{{ client.email or client.contact }}">{{ client.email or client.contact }}</a></dd>
      </div>
      {% endif %}
      {% if client.phone %}
      <div>
        <dt>Phone</dt>
        <dd><a href="tel:{{ client.phone }}">{{ client.phone }}</a></dd>
      </div>
      {% endif %}
      {% if client.linkedin %}
      <div>
        <dt>LinkedIn</dt>
        <dd><a href="{{ client.linkedin }}" target="_blank" rel="noopener">Profile</a></dd>
      </div>
      {% endif %}
      {% if calls and calls.length %}
      <div>
        <dt>Last call</dt>
        <dd>{{ calls[0].date }}</dd>
      </div>
      <div>
        <dt>Total calls</dt>
        <dd>{{ calls | length }}</dd>
      </div>
      {% endif %}
    </dl>
  </div>
  <div class="button-stack">
    <a class="btn" href="{{ client.requestUrl or settings.defaultRequestUrl }}" target="_blank">Request a change</a>
    <button class="btn btn-secondary" onclick="atlasLogout()">Log out</button>
  </div>
</section>

<section class="grid">
{% for project in projects %}
  <article class="card">
    <div class="card-header">
      <h3>{{ project.name }}</h3>
      <span class="status-pill {{ project.stage | lower | replace(' ', '-') }}">{{ project.stage }}</span>
    </div>
    {% if project.thumbnailUrl %}
    <div class="thumb-wrapper">
      <img class="site-thumb" src="{{ project.thumbnailUrl }}" alt="Preview of {{ project.name }}">
    </div>
    {% endif %}
    <p>{{ project.summary }}</p>
    <dl class="meta">
      <div><dt>Status</dt><dd>{{ project.status }}</dd></div>
      <div><dt>Last update</dt><dd>{{ project.lastUpdate | date('MMM d, yyyy') }}</dd></div>
    </dl>
    <div class="links">
      {% if project.previewUrl %}<a href="{{ project.previewUrl }}" target="_blank">Open site</a>{% endif %}
      <a href="{{ client.requestUrl or settings.defaultRequestUrl }}" class="secondary" target="_blank">Request change</a>
      <button class="btn btn-ghost btn-sm edit-btn" onclick="openProjectEditor(this, event)" data-noportal
              data-id="{{ project.id }}"
              data-name="{{ project.name }}"
              data-status="{{ project.status }}"
              data-summary="{{ project.summary }}"
              data-owner="{{ project.owner }}"
              data-stage="{{ project.stage }}"
              data-preview="{{ project.previewUrl }}"
              data-repo="{{ project.repoUrl }}">
        ✏️ Edit
      </button>
    </div>
    {# ── Project Brain ── #}
    <section class="brain-section" id="brain-{{ project.id }}">
      <div class="brain-panel">
        <div class="brain-links-section">
          <div class="brain-sub-header">
            <span class="brain-sub-title">🔗 Links &amp; resources</span>
            <button type="button" class="btn btn-ghost btn-sm" onclick="addBrainLink('{{ project.id }}')">+ Add link</button>
          </div>
          <div class="brain-links-list" id="bl-{{ project.id }}"></div>
        </div>
        <div class="brain-notes-section">
          <div class="brain-sub-header">
            <span class="brain-sub-title">📝 Notes &amp; context</span>
            <div class="brain-add-btns">
              <button type="button" class="btn btn-ghost btn-sm" onclick="addBrainNote('{{ project.id }}')">+ Add note</button>
              <label class="btn btn-ghost btn-sm brain-upload-label">
                📎 Upload file
                <input type="file" accept=".txt,.md,.html,.csv,.json" style="display:none" onchange="uploadBrainFile(this, '{{ project.id }}')">
              </label>
            </div>
          </div>
          <div class="brain-notes-list" id="bn-{{ project.id }}"></div>
          <p class="brain-hint muted">Supports .txt, .md, .html, .csv · Paste any text as a note</p>
        </div>
        <div class="brain-actions">
          <button class="btn btn-primary btn-sm" onclick="saveBrainFromPage('{{ project.id }}', 'project', this)">💾 Save brain</button>
          <span class="brain-save-status" id="bss-{{ project.id }}"></span>
        </div>
      </div>
    </section>

    {# ── Inline editor panel ── #}
    <div class="project-editor" id="editor-{{ project.id }}" style="display:none" data-noportal data-project-id="{{ project.id }}" onclick="event.stopPropagation()">
      <div class="editor-grid">
        <div class="editor-field editor-full">
          <label>Project name</label>
          <input type="text" class="ef-name" placeholder="Project name">
        </div>
        <div class="editor-field">
          <label>Owner</label>
          <input type="text" class="ef-owner" placeholder="Owner">
        </div>
        <div class="editor-field">
          <label>Stage</label>
          <select class="ef-stage">
            <option value="Lead">Lead</option>
            <option value="Client">Client</option>
            <option value="Internal">Internal</option>
            <option value="Contractor">Contractor</option>
            <option value="Paused">Paused</option>
            <option value="Done">Done</option>
          </select>
        </div>
        <div class="editor-field editor-full">
          <label>Status / summary</label>
          <input type="text" class="ef-status" placeholder="One-line status">
        </div>
        <div class="editor-field">
          <label>Preview URL</label>
          <input type="url" class="ef-preview" placeholder="https://">
        </div>
        <div class="editor-field">
          <label>Repo URL</label>
          <input type="url" class="ef-repo" placeholder="https://github.com/...">
        </div>
      </div>

      <div class="editor-actions">
        <button class="btn btn-primary btn-sm" onclick="saveProjectEditor('{{ project.id }}', this)" data-noportal>Save changes</button>
        <button class="btn btn-ghost btn-sm" onclick="closeProjectEditor('{{ project.id }}')" data-noportal>Cancel</button>
        <span class="editor-save-status" id="es-{{ project.id }}"></span>
      </div>
    </div>
  </article>
{% else %}
  <p class="muted">No live projects yet.</p>
{% endfor %}
</section>

<!-- ── Fathom Call History (static) ──────────────────────────────────── -->
{% if calls and calls.length %}
<section class="call-history-section" id="call-history">
  <div class="section-header">
    <div>
      <h3>📞 Call History</h3>
      <p class="muted">{{ calls | length }} recording{{ 's' if calls | length != 1 }} · Last call {{ calls[0].date }}</p>
    </div>
  </div>
  <div class="call-cards">
    {% for call in calls %}
    <details class="call-card">
      <summary class="call-card-header">
        <span class="call-icon">📞</span>
        <span class="call-date">{{ call.date }}</span>
        <span class="call-title">{{ call.title }}</span>
        <span class="call-chevron">▸</span>
      </summary>
      <div class="call-card-body">
        {% if call.participants and call.participants | length %}
        <p class="call-participants">👥 {{ call.participants | join(', ') }}</p>
        {% endif %}
        {% if call.key_takeaways and call.key_takeaways | length %}
        <div class="call-section">
          <h5>Key Takeaways</h5>
          <ul class="call-list">
            {% for kt in call.key_takeaways %}<li>{{ kt }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        {% if call.next_steps and call.next_steps | length %}
        <div class="call-section">
          <h5>Next Steps</h5>
          <ul class="call-list">
            {% for ns in call.next_steps %}<li>{{ ns }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        <div class="call-footer">
          {% if call.share_url %}<a href="{{ call.share_url }}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">▶ View recording</a>{% endif %}
          {% if call.fathom_url %}<a href="{{ call.fathom_url }}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">Full transcript</a>{% endif %}
          <button class="btn btn-ghost btn-sm call-move-btn"
                  onclick="toggleCallMover(this, '{{ call.recording_id }}')"
                  data-rid="{{ call.recording_id }}">📁 Move</button>
        </div>
        <div class="call-mover" id="cm-{{ call.recording_id }}" style="display:none">
          <select class="call-mover-select">
            <option value="">— Move to project —</option>
            {% if allProjects %}
            {% for p in allProjects | sort(attribute='name') %}
            <option value="{{ p.id }}"{% if p.id == call.project_id %} selected{% endif %}>{{ p.name }}</option>
            {% endfor %}
            {% endif %}
            <option value="__new__">＋ Create new project…</option>
          </select>
          <button class="btn btn-primary btn-sm" onclick="moveCall('{{ call.recording_id }}', this)">Move</button>
          <span class="call-mover-status" id="cms-{{ call.recording_id }}"></span>
        </div>
      </div>
    </details>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ── Notes (manual, saved to Notion) ───────────────────────────────── -->
<section class="notion-activity" id="notion-activity">
  <div class="section-header">
    <div>
      <h3>Notes</h3>
      <p class="muted" id="activity-subtitle">Loading…</p>
    </div>
  </div>

  <div class="note-form-wrap">
    <details class="note-form-toggle">
      <summary class="btn btn-secondary">+ Add a note</summary>
      <form class="note-form" id="note-form" onsubmit="submitNote(event, '{{ client.slug }}', 'client')">
        <textarea id="note-text" placeholder="Write your note…" rows="4" required></textarea>
        <div class="note-form-footer">
          <input type="text" id="note-author" placeholder="Your name (optional)" />
          <button type="submit" class="btn" id="note-submit-btn">Save note</button>
        </div>
        <p class="note-form-status muted" id="note-status" style="display:none"></p>
      </form>
    </details>
  </div>

  <div id="notes-section" style="display:none">
    <h4 class="activity-group-label">Notes</h4>
    <div id="notes-list" class="activity-list"></div>
  </div>

  <p class="muted" id="activity-empty" style="display:none">No notes yet.</p>
</section>

<script>
function atlasLogout() {
  localStorage.removeItem('atlas_token');
  localStorage.removeItem('atlas_client_slug');
  window.location.href = '../login.html';
}

// ── Load notes from Notion API ───────────────────────────────────────────
(function loadNotionActivity() {
  var slug = '{{ client.slug }}';
  fetch('/api/notion-clients?slug=' + encodeURIComponent(slug))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var notes = data.notes || [];
      document.getElementById('activity-subtitle').textContent =
        notes.length === 0 ? 'No notes yet' :
        notes.length + ' note' + (notes.length !== 1 ? 's' : '');
      if (notes.length === 0) {
        document.getElementById('activity-empty').style.display = '';
        return;
      }
      var notesList = document.getElementById('notes-list');
      notes.forEach(function(note) {
        notesList.appendChild(buildNoteCard(note));
      });
      document.getElementById('notes-section').style.display = '';
    })
    .catch(function(err) {
      document.getElementById('activity-subtitle').textContent = 'Could not load notes';
      console.warn('Notion notes load error:', err);
    });
})();

function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function buildNoteCard(note) {
  var el = document.createElement('div');
  el.className = 'activity-card note-card';
  var author = note.author ? ' <span class="note-author">by ' + esc(note.author) + '</span>' : '';
  el.innerHTML =
    '<div class="activity-card-header">' +
      '<span class="activity-icon">📝</span>' +
      '<span class="activity-date">' + esc(note.date || '') + author + '</span>' +
    '</div>' +
    '<div class="activity-body">' +
      note.content.map(function(c) { return '<p>' + esc(c) + '</p>'; }).join('') +
    '</div>';
  return el;
}

// ── Submit note ─────────────────────────────────────────────────────────
async function submitNote(event, slug, dbType) {
  event.preventDefault();
  var text = document.getElementById('note-text').value.trim();
  var author = document.getElementById('note-author').value.trim();
  var btn = document.getElementById('note-submit-btn');
  var status = document.getElementById('note-status');
  if (!text) return;

  btn.disabled = true;
  btn.textContent = 'Saving…';
  status.style.display = 'none';

  var endpoint = dbType === 'partner' ? '/api/notion-partners' : '/api/notion-clients';
  try {
    var res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: slug, text: text, author: author || undefined, type: 'note' })
    });
    if (res.ok) {
      status.textContent = '✅ Note saved to Notion.';
      status.style.color = 'var(--accent)';
      document.getElementById('note-text').value = '';
      // Prepend new note card to notes list immediately
      var notesList = document.getElementById('notes-list');
      var today = new Date().toISOString().split('T')[0];
      var fakeNote = { date: today, author: author || '', content: [text] };
      notesList.prepend(buildNoteCard(fakeNote));
      document.getElementById('notes-section').style.display = '';
    } else {
      status.textContent = '⚠️ Failed to save. Please try again.';
      status.style.color = '#fdb874';
    }
  } catch(e) {
    status.textContent = '⚠️ Network error. Please try again.';
    status.style.color = '#fdb874';
  }
  status.style.display = '';
  btn.disabled = false;
  btn.textContent = 'Save note';
}

/* ── Move call to different project ── */
function toggleCallMover(btn, rid) {
  var mover = document.getElementById('cm-' + rid);
  if (!mover) return;
  mover.style.display = mover.style.display === 'none' ? 'flex' : 'none';
}

async function moveCall(rid, btn) {
  var mover = document.getElementById('cm-' + rid);
  var sel = mover.querySelector('.call-mover-select');
  var statusEl = document.getElementById('cms-' + rid);
  var projectId = sel ? sel.value : '';
  if (!projectId) { statusEl.textContent = 'Pick a project'; statusEl.style.color = '#f87171'; return; }
  if (projectId === '__new__') {
    // Pre-fill the create modal with this single call
    if (typeof openNewProjectModal === 'function') {
      // Store rid for linking after creation — store on window for now
      window._pendingLinkCallIds = [rid];
      openNewProjectModal();
    }
    return;
  }
  var projectName = sel.options[sel.selectedIndex].text;
  btn.disabled = true;
  statusEl.textContent = '⟳';
  statusEl.style.color = 'var(--muted)';
  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'link-calls', callIds: [String(rid)], projectId: projectId })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Moved to ' + projectName;
      statusEl.style.color = '#4ade80';
      // Grey out the card so it's clear it moved
      var card = mover.closest('.call-card');
      if (card) card.style.opacity = '0.45';
      mover.style.display = 'none';
    } else {
      statusEl.textContent = '✗ ' + (d.error || 'Error');
      statusEl.style.color = '#f87171';
      btn.disabled = false;
    }
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.style.color = '#f87171';
    btn.disabled = false;
  }
}

// ── Brain init for all projects on this page ──────────────────────────
(function initProjectBrains() {
  var brainData = {
    {% for project in projects %}
    '{{ project.id }}': {
      links: {{ (project.brain.links if project.brain else []) | dump }},
      notes: {{ (project.brain.notes if project.brain else []) | dump }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  };
  Object.keys(brainData).forEach(function(id) {
    var d = brainData[id];
    renderBrainLinks(id, d.links || []);
    renderBrainNotes(id, d.notes || []);
  });
})();

/* ── Brain (links + notes) ── */
function renderBrainLinks(projectId, links) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return;
  list.innerHTML = '';
  (links || []).forEach(function(l, i) { list.appendChild(makeBrainLinkRow(projectId, l, i)); });
  updateBrainBadge(projectId);
}

function renderBrainNotes(projectId, notes) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.innerHTML = '';
  (notes || []).forEach(function(n, i) { list.appendChild(makeBrainNoteRow(projectId, n, i)); });
  updateBrainBadge(projectId);
}

function makeBrainLinkRow(projectId, l, idx) {
  var row = document.createElement('div');
  row.className = 'brain-link-row';
  row.dataset.idx = idx;
  row.innerHTML =
    '<input type="url"  class="bl-url"   placeholder="https://" value="' + esc(l.url   || '') + '">' +
    '<input type="text" class="bl-label" placeholder="Label"    value="' + esc(l.label || '') + '">' +
    '<button type="button" class="btn btn-ghost btn-sm" onclick="removeBrainRow(this)">✕</button>';
  return row;
}

function makeBrainNoteRow(projectId, n, idx) {
  var row = document.createElement('div');
  row.className = 'brain-note-row';
  row.dataset.idx = idx;
  var text = typeof n === 'string' ? n : (n.text || '');
  row.innerHTML =
    '<textarea class="bn-text" placeholder="Note or context…" rows="3">' + esc(text) + '</textarea>' +
    '<button type="button" class="btn btn-ghost btn-sm" onclick="removeBrainRow(this)">✕</button>';
  return row;
}

function addBrainLink(projectId) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainLinkRow(projectId, {}, list.children.length));
}

function addBrainNote(projectId) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainNoteRow(projectId, '', list.children.length));
}

function removeBrainRow(btn) {
  var row = btn.closest('.brain-link-row, .brain-note-row');
  if (row) row.remove();
}

function collectBrainLinks(projectId) {
  var list = document.getElementById('bl-' + projectId);
  if (!list) return [];
  return Array.from(list.querySelectorAll('.brain-link-row')).map(function(row) {
    var url   = row.querySelector('.bl-url').value.trim();
    var label = row.querySelector('.bl-label').value.trim();
    if (!url) return null;
    return { url: url, label: label || url };
  }).filter(Boolean);
}

function collectBrainNotes(projectId) {
  var list = document.getElementById('bn-' + projectId);
  if (!list) return [];
  return Array.from(list.querySelectorAll('.brain-note-row')).map(function(row) {
    var text = row.querySelector('.bn-text').value.trim();
    return text || null;
  }).filter(Boolean);
}

function updateBrainBadge(projectId) {
  var badge = document.getElementById('bb-' + projectId);
  if (!badge) return;
  var linkCount = (document.getElementById('bl-' + projectId) || { children: [] }).children.length;
  var noteCount = (document.getElementById('bn-' + projectId) || { children: [] }).children.length;
  var total = linkCount + noteCount;
  badge.textContent = total > 0 ? '(' + total + ')' : '';
}

async function uploadBrainFile(input, projectId) {
  var file = input.files[0];
  if (!file) return;
  var text = await file.text();
  var list = document.getElementById('bn-' + projectId);
  if (!list) return;
  list.appendChild(makeBrainNoteRow(projectId, text.slice(0, 8000), list.children.length));
  updateBrainBadge(projectId);
  input.value = '';
}

async function saveBrainFromPage(entityId, entityType, btn) {
  var statusEl = document.getElementById('bss-' + entityId);
  btn.disabled = true;
  if (statusEl) { statusEl.textContent = '⟳ Saving…'; statusEl.style.color = 'var(--muted)'; }

  var links = collectBrainLinks(entityId);
  var notes = collectBrainNotes(entityId);

  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        entityType: entityType,
        entityId:   entityId,
        updates: {
          'brain.links': links.length ? links : null,
          'brain.notes': notes.length ? notes : null
        }
      })
    });
    var d = await r.json();
    if (d.ok) {
      if (statusEl) { statusEl.textContent = '✓ Saved!'; statusEl.style.color = '#4ade80'; }
      updateBrainBadge(entityId);
      setTimeout(function() { if (statusEl) statusEl.textContent = ''; }, 3000);
    } else {
      if (statusEl) { statusEl.textContent = '✗ ' + (d.error || 'Error'); statusEl.style.color = '#f87171'; }
    }
  } catch(e) {
    if (statusEl) { statusEl.textContent = '✗ Network error'; statusEl.style.color = '#f87171'; }
  }
  btn.disabled = false;
}

/* ── Project inline editor ── */
function openProjectEditor(btn, evt) {
  evt.stopPropagation();
  var id = btn.dataset.id;
  var editor = document.getElementById('editor-' + id);
  if (!editor) return;
  // Close any other open editors
  document.querySelectorAll('.project-editor').forEach(function(e) {
    if (e !== editor) e.style.display = 'none';
  });
  // Populate fields
  editor.querySelector('.ef-name').value    = btn.dataset.name    || '';
  editor.querySelector('.ef-owner').value   = btn.dataset.owner   || '';
  editor.querySelector('.ef-status').value  = btn.dataset.status  || '';
  editor.querySelector('.ef-preview').value = btn.dataset.preview || '';
  editor.querySelector('.ef-repo').value    = btn.dataset.repo    || '';
  // Stage select
  editor.querySelector('.ef-stage').value = btn.dataset.stage || 'Lead';
  editor.style.display = 'block';
  editor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function closeProjectEditor(id) {
  var editor = document.getElementById('editor-' + id);
  if (editor) editor.style.display = 'none';
}

async function saveProjectEditor(id, btn) {
  var editor = document.getElementById('editor-' + id);
  var statusEl = document.getElementById('es-' + id);
  statusEl.textContent = '⟳ Saving…';
  statusEl.style.color = 'var(--muted)';
  btn.disabled = true;

  var updates = {
    name:       editor.querySelector('.ef-name').value.trim(),
    owner:      editor.querySelector('.ef-owner').value.trim(),
    stage:      editor.querySelector('.ef-stage').value,
    status:     editor.querySelector('.ef-status').value.trim(),
    previewUrl: editor.querySelector('.ef-preview').value.trim() || null,
    repoUrl:    editor.querySelector('.ef-repo').value.trim() || null,
    lastUpdate: new Date().toISOString().slice(0, 10)
  };

  try {
    var r = await fetch('/api/update-field', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ entityType: 'project', entityId: id, updates: updates })
    });
    var d = await r.json();
    if (d.ok) {
      statusEl.textContent = '✓ Saved — rebuilding…';
      statusEl.style.color = '#4ade80';
      // Update the edit button's data attrs so re-open shows fresh data
      var editBtn = editor.previousElementSibling && editor.previousElementSibling.querySelector('.edit-btn')
                 || document.querySelector('[data-id="' + id + '"]');
      if (editBtn) {
        editBtn.dataset.name    = updates.name;
        editBtn.dataset.owner   = updates.owner;
        editBtn.dataset.stage   = updates.stage;
        editBtn.dataset.status  = updates.status;
        editBtn.dataset.preview = updates.previewUrl || '';
        editBtn.dataset.repo    = updates.repoUrl    || '';
        // Update visible card fields immediately
        var card = editor.closest('.card');
        if (card) {
          var h3 = card.querySelector('h3'); if (h3) h3.textContent = updates.name;
          var statusDd = card.querySelector('.meta dd'); if (statusDd) statusDd.textContent = updates.status;
          var stagePill = card.querySelector('.status-pill');
          if (stagePill) {
            stagePill.textContent = updates.stage;
            stagePill.className = 'status-pill ' + updates.stage.toLowerCase().replace(/ /g, '-');
          }
          var summaryP = card.querySelector('p'); if (summaryP) summaryP.textContent = updates.status;
          // Update preview link if it exists
          var previewLink = card.querySelector('.links a[href*="://"]');
          if (previewLink && updates.previewUrl) {
            previewLink.href = updates.previewUrl;
          } else if (previewLink && !updates.previewUrl) {
            previewLink.style.display = 'none';
          } else if (!previewLink && updates.previewUrl) {
            // Add preview link if it doesn't exist but now has URL
            var linksDiv = card.querySelector('.links');
            if (linksDiv) {
              var newLink = document.createElement('a');
              newLink.href = updates.previewUrl;
              newLink.target = '_blank';
              newLink.textContent = 'Open site';
              linksDiv.insertBefore(newLink, linksDiv.firstChild);
            }
          }
        }
      }
      closeProjectEditor(id);
      setTimeout(function() { if (statusEl) statusEl.textContent = ''; }, 3000);
    } else {
      statusEl.textContent = '✗ ' + (d.error || 'Error');
      statusEl.style.color = '#f87171';
      btn.disabled = false;
    }
  } catch(e) {
    statusEl.textContent = '✗ Network error';
    statusEl.style.color = '#f87171';
    btn.disabled = false;
  }
}

</script>
