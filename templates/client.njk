<script>
(function() {
  var slug = '{{ client.slug }}';
  var token = localStorage.getItem('atlas_token');
  var storedSlug = localStorage.getItem('atlas_client_slug');
  if (!token || (storedSlug !== slug && storedSlug !== 'admin')) {
    window.location.href = '../login.html?redirect=' + encodeURIComponent(window.location.pathname);
    return;
  }
  fetch('/api/verify', { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.valid || (data.clientSlug !== slug && data.clientSlug !== 'admin')) {
        localStorage.removeItem('atlas_token');
        localStorage.removeItem('atlas_client_slug');
        window.location.href = '../login.html?redirect=' + encodeURIComponent(window.location.pathname);
        return;
      }
      if (data.mustChangePassword) {
        window.location.href = '../change-password.html';
      }
    })
    .catch(function() {});
})();
</script>

<section class="client-info">
  <div>
    <h2>{{ client.name }}</h2>
    {% if client.summary %}<p>{{ client.summary }}</p>{% endif %}
    <dl class="contact-meta">
      {% if client.email or client.contact %}
      <div>
        <dt>Email</dt>
        <dd><a href="mailto:{{ client.email or client.contact }}">{{ client.email or client.contact }}</a></dd>
      </div>
      {% endif %}
      {% if client.phone %}
      <div>
        <dt>Phone</dt>
        <dd><a href="tel:{{ client.phone }}">{{ client.phone }}</a></dd>
      </div>
      {% endif %}
      {% if client.linkedin %}
      <div>
        <dt>LinkedIn</dt>
        <dd><a href="{{ client.linkedin }}" target="_blank" rel="noopener">Profile</a></dd>
      </div>
      {% endif %}
      {% if calls and calls.length %}
      <div>
        <dt>Last call</dt>
        <dd>{{ calls[0].date }}</dd>
      </div>
      <div>
        <dt>Total calls</dt>
        <dd>{{ calls | length }}</dd>
      </div>
      {% endif %}
    </dl>
  </div>
  <div class="button-stack">
    <a class="btn" href="{{ client.requestUrl or settings.defaultRequestUrl }}" target="_blank">Request a change</a>
    <button class="btn btn-secondary" onclick="atlasLogout()">Log out</button>
  </div>
</section>

<section class="grid">
{% for project in projects %}
  <article class="card">
    <div class="card-header">
      <h3>{{ project.name }}</h3>
      <span class="status-pill {{ project.stage | lower | replace(' ', '-') }}">{{ project.stage }}</span>
    </div>
    {% if project.thumbnailUrl %}
    <div class="thumb-wrapper">
      <img class="site-thumb" src="{{ project.thumbnailUrl }}" alt="Preview of {{ project.name }}">
    </div>
    {% endif %}
    <p>{{ project.summary }}</p>
    <dl class="meta">
      <div><dt>Status</dt><dd>{{ project.status }}</dd></div>
      <div><dt>Last update</dt><dd>{{ project.lastUpdate | date('MMM d, yyyy') }}</dd></div>
    </dl>
    <div class="links">
      {% if project.previewUrl %}<a href="{{ project.previewUrl }}" target="_blank">Open site</a>{% endif %}
      <a href="{{ client.requestUrl or settings.defaultRequestUrl }}" class="secondary" target="_blank">Request change</a>
    </div>
  </article>
{% else %}
  <p class="muted">No live projects yet.</p>
{% endfor %}
</section>

<!-- ── Fathom Call History (static) ──────────────────────────────────── -->
{% if calls and calls.length %}
<section class="call-history-section" id="call-history">
  <div class="section-header">
    <div>
      <h3>📞 Call History</h3>
      <p class="muted">{{ calls | length }} recording{{ 's' if calls | length != 1 }} · Last call {{ calls[0].date }}</p>
    </div>
  </div>
  <div class="call-cards">
    {% for call in calls %}
    <details class="call-card">
      <summary class="call-card-header">
        <span class="call-icon">📞</span>
        <span class="call-date">{{ call.date }}</span>
        <span class="call-title">{{ call.title }}</span>
        <span class="call-chevron">▸</span>
      </summary>
      <div class="call-card-body">
        {% if call.participants and call.participants | length %}
        <p class="call-participants">👥 {{ call.participants | join(', ') }}</p>
        {% endif %}
        {% if call.key_takeaways and call.key_takeaways | length %}
        <div class="call-section">
          <h5>Key Takeaways</h5>
          <ul class="call-list">
            {% for kt in call.key_takeaways %}<li>{{ kt }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        {% if call.next_steps and call.next_steps | length %}
        <div class="call-section">
          <h5>Next Steps</h5>
          <ul class="call-list">
            {% for ns in call.next_steps %}<li>{{ ns }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        <div class="call-footer">
          {% if call.share_url %}<a href="{{ call.share_url }}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">▶ View recording</a>{% endif %}
          {% if call.fathom_url %}<a href="{{ call.fathom_url }}" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">Full transcript</a>{% endif %}
        </div>
      </div>
    </details>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ── Notes (manual, saved to Notion) ───────────────────────────────── -->
<section class="notion-activity" id="notion-activity">
  <div class="section-header">
    <div>
      <h3>Notes</h3>
      <p class="muted" id="activity-subtitle">Loading…</p>
    </div>
  </div>

  <div class="note-form-wrap">
    <details class="note-form-toggle">
      <summary class="btn btn-secondary">+ Add a note</summary>
      <form class="note-form" id="note-form" onsubmit="submitNote(event, '{{ client.slug }}', 'client')">
        <textarea id="note-text" placeholder="Write your note…" rows="4" required></textarea>
        <div class="note-form-footer">
          <input type="text" id="note-author" placeholder="Your name (optional)" />
          <button type="submit" class="btn" id="note-submit-btn">Save note</button>
        </div>
        <p class="note-form-status muted" id="note-status" style="display:none"></p>
      </form>
    </details>
  </div>

  <div id="notes-section" style="display:none">
    <h4 class="activity-group-label">Notes</h4>
    <div id="notes-list" class="activity-list"></div>
  </div>

  <p class="muted" id="activity-empty" style="display:none">No notes yet.</p>
</section>

<script>
function atlasLogout() {
  localStorage.removeItem('atlas_token');
  localStorage.removeItem('atlas_client_slug');
  window.location.href = '../login.html';
}

// ── Load notes from Notion API ───────────────────────────────────────────
(function loadNotionActivity() {
  var slug = '{{ client.slug }}';
  fetch('/api/notion-clients?slug=' + encodeURIComponent(slug))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var notes = data.notes || [];
      document.getElementById('activity-subtitle').textContent =
        notes.length === 0 ? 'No notes yet' :
        notes.length + ' note' + (notes.length !== 1 ? 's' : '');
      if (notes.length === 0) {
        document.getElementById('activity-empty').style.display = '';
        return;
      }
      var notesList = document.getElementById('notes-list');
      notes.forEach(function(note) {
        notesList.appendChild(buildNoteCard(note));
      });
      document.getElementById('notes-section').style.display = '';
    })
    .catch(function(err) {
      document.getElementById('activity-subtitle').textContent = 'Could not load notes';
      console.warn('Notion notes load error:', err);
    });
})();

function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function buildNoteCard(note) {
  var el = document.createElement('div');
  el.className = 'activity-card note-card';
  var author = note.author ? ' <span class="note-author">by ' + esc(note.author) + '</span>' : '';
  el.innerHTML =
    '<div class="activity-card-header">' +
      '<span class="activity-icon">📝</span>' +
      '<span class="activity-date">' + esc(note.date || '') + author + '</span>' +
    '</div>' +
    '<div class="activity-body">' +
      note.content.map(function(c) { return '<p>' + esc(c) + '</p>'; }).join('') +
    '</div>';
  return el;
}

// ── Submit note ─────────────────────────────────────────────────────────
async function submitNote(event, slug, dbType) {
  event.preventDefault();
  var text = document.getElementById('note-text').value.trim();
  var author = document.getElementById('note-author').value.trim();
  var btn = document.getElementById('note-submit-btn');
  var status = document.getElementById('note-status');
  if (!text) return;

  btn.disabled = true;
  btn.textContent = 'Saving…';
  status.style.display = 'none';

  var endpoint = dbType === 'partner' ? '/api/notion-partners' : '/api/notion-clients';
  try {
    var res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: slug, text: text, author: author || undefined, type: 'note' })
    });
    if (res.ok) {
      status.textContent = '✅ Note saved to Notion.';
      status.style.color = 'var(--accent)';
      document.getElementById('note-text').value = '';
      // Prepend new note card to notes list immediately
      var notesList = document.getElementById('notes-list');
      var today = new Date().toISOString().split('T')[0];
      var fakeNote = { date: today, author: author || '', content: [text] };
      notesList.prepend(buildNoteCard(fakeNote));
      document.getElementById('notes-section').style.display = '';
    } else {
      status.textContent = '⚠️ Failed to save. Please try again.';
      status.style.color = '#fdb874';
    }
  } catch(e) {
    status.textContent = '⚠️ Network error. Please try again.';
    status.style.color = '#fdb874';
  }
  status.style.display = '';
  btn.disabled = false;
  btn.textContent = 'Save note';
}
</script>
